    console.log(`→ enrich (claude --model opus) [${row.repo}]: ${row.body.slice(0, 80)}…`);
    const result = enrichTaskBody(row.body, repoPath);
    const applied = applyEnrichment(db, TASKS_PATH, id, result);
    if (applied.kind === "questions") {
      console.log(`? questions stored on draft (status unchanged):`);
      console.log(applied.questions);
      console.log(``);
      console.log(`Answer the questions, edit the draft body in TASKS.md, then re-run: batonq enrich ${id}`);
    } else {
      console.log(`✓ enriched. Body + verify/judge updated. Status still draft.`);
      if (applied.newExternalId !== applied.oldExternalId) {
        console.log(`  external_id: ${applied.oldExternalId} → ${applied.newExternalId}`);
      }
