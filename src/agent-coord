// ── release ───────────────────────────────────────────────────────────────────

function release(path: string | undefined) {
  if (!path) {
    console.error("usage: batonq release <path>");
    process.exit(2);
  }
  if (!existsSync(DB_PATH)) {
    console.log("(no state.db — nothing to release)");
    return;
  }
  const abs = isAbsolute(path) ? path : resolve(process.cwd(), path);
  const db = new Database(DB_PATH);
  db.exec("PRAGMA busy_timeout=3000;");
  const r = db.run(
    `UPDATE claims SET released_at = ? WHERE file_path = ? AND released_at IS NULL`,
    [new Date().toISOString(), abs]
  );
  console.log(`Released ${r.changes} active claim(s) on ${abs}`);
  db.close();
}

// ── sweep ─────────────────────────────────────────────────────────────────────

function sweepCmd() {
  if (!existsSync(DB_PATH)) {
    console.log("(no state.db — nothing to sweep)");
    return;
  }
  const db = new Database(DB_PATH);
  db.exec("PRAGMA busy_timeout=3000;");
  const now = new Date().toISOString();
  const expired = db.run(
    `UPDATE claims SET released_at = ? WHERE released_at IS NULL AND expires_at < ?`,
    [now, now]
  );
  const cutoff = new Date(Date.now() - 30 * 60_000).toISOString();
  const staleS = db.run(`DELETE FROM sessions WHERE last_seen < ?`, [cutoff]);
  console.log(`Swept: ${expired.changes} expired claim(s), ${staleS.changes} stale session(s).`);
  db.close();
}

// sweep-tasks: distinct from `sweep` (which releases file-claims and expires
// sessions). Walks claimed tasks whose last progress predates the TTL, runs
// the recovery hook on each, and either defers live-but-quiet holders or
// flips dead holders to status=lost and appends an escalation log line.
function sweepTasksCmd() {
  if (!existsSync(DB_PATH)) {
    console.log("(no state.db — nothing to sweep)");
    return;
  }
  const db = openTaskDb();
  try {
    const res = sweepTasksCore(db);
    console.log(
      `Swept tasks: ${res.lost} lost, ${res.deferred} deferred (scanned ${res.scanned}).`
    );
  } finally {
    db.close();
  }
}

// ── tasks ─────────────────────────────────────────────────────────────────────

function parseTasksFile(): { lines: string[]; tasks: ParsedTask[] } {
  return parseTasksFileCore(TASKS_PATH);
}

function openTaskDb(): Database {
  const db = new Database(DB_PATH, { create: true });
  db.exec("PRAGMA busy_timeout=3000;");
  initTaskSchema(db);
  // sweepTasks (and anything else that joins against sessions for liveness)
  // needs the sessions/claims tables even if the hook has never run in this
  // $HOME yet. Keeping the schema init colocated with openTaskDb makes the
  // CLI self-sufficient on a fresh install.
  initClaimsSchema(db);
  return db;
}

function syncTasks(verbose: boolean): { added: number; completed: number; parsed: number } {
  const { tasks: parsed } = parseTasksFile();
  const db = openTaskDb();
  let result;
  try {
    result = syncTasksCore(db, parsed);
  } finally {
    db.close();
  }
  if (verbose) {
    console.log(
      `Synced ${result.parsed} task(s) from ${TASKS_PATH}: ${result.added} new, ${result.completed} newly marked done.`
    );
  }
  return result;
}

function getRepoForCwd(): string | null {
  try {
    const root = execSync("git rev-parse --show-toplevel", {
      stdio: ["ignore", "pipe", "ignore"],
    })
      .toString()
      .trim();
    return root ? basename(root) : null;
  } catch {
    return null;
  }
}

function currentSession(): string {
  // Session identifier per terminal: TTY + shell PID.
  // Not Claude's session_id (not available here), but stable within a single Warp tab's lifetime.
  try {
    const tty = execSync("tty", { stdio: ["ignore", "pipe", "ignore"] })
      .toString()
      .trim()
      .replace("/dev/", "");
    return `term_${tty}_${process.ppid}`;
  } catch {
    return `pid_${process.ppid}`;
  }
}

function pickTask(): void {
  syncTasks(false);
  const db = openTaskDb();
  try {
    // Auto-sweep task-TTLs before picking so stale claims don't block the
    // queue. Keeps the sweep hot path inline with pick instead of relying
    // on a cron — the most reliable trigger is "another agent wants work".
    sweepTasksCore(db);

    const repo = getRepoForCwd();
    const session = currentSession();
    const args = process.argv.slice(3);
    const any = args.includes("--any");

    const candidate: any = selectCandidate(db, { repo, any });
    if (!candidate) {
      console.log("NO_TASK");
      if (any) {
        console.log(`No pending tasks in the queue at ${TASKS_PATH}`);
      } else if (repo) {
        console.log(`No pending tasks for repo "${repo}" (or any:* tasks). Queue: ${TASKS_PATH}`);
      } else {
        console.log(
          `No pending any:* tasks (current cwd is not in a git-repo; use --any to pick any task, or cd into a repo).`
        );
      }
      return;
    }
    const result = claimCandidate(db, candidate.id, session);
    if (result.changes === 0) {
      console.log("NO_TASK");
      console.log("Task was claimed by another session between sync and claim. Run /pick-next again.");
      return;
    }
    console.log(`TASK_CLAIMED`);
    console.log(`external_id: ${candidate.external_id}`);
    console.log(`repo:        ${candidate.repo}`);
    console.log(`session:     ${session}`);
    console.log(``);
    console.log(`TASK:`);
    console.log(candidate.body);
    console.log(``);
    console.log(`When complete:   batonq done ${candidate.external_id}`);
    console.log(`If abandoning:   batonq abandon ${candidate.external_id}`);
  } finally {
    db.close();
  }
}

