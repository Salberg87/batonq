    db.close();
  }
}

// Synchronous y/n prompt. Returns `def` when stdin is not a TTY (piped/CI)
// so non-interactive callers don't deadlock waiting for input.
function promptYesNo(question: string, def: boolean): boolean {
  if (!process.stdin.isTTY) return def;
  const yn = def ? "[Y/n]" : "[y/N]";
  process.stdout.write(`${question} ${yn} `);
  const buf = Buffer.alloc(64);
  let n = 0;
  try {
    n = readSync(0, buf, 0, buf.length, null);
  } catch {
    return def;
  }
  const ans = buf.toString("utf8", 0, n).trim().toLowerCase();
  if (ans === "") return def;
  return ans === "y" || ans === "yes";
}

// ── version ───────────────────────────────────────────────────────────────────

function printVersion(): void {
  // pkgJson is statically imported (top of file) so the bundler inlines it.
  // The previous implementation read package.json via import.meta.url, which
  // resolves to /$bunfs/root/ inside a `bun build --compile` binary — the
  // file is not on disk there, so installed binaries always printed
  // "vunknown". Static import works in both dev (bun run) and compiled mode.
  const version =
    (pkgJson as { version?: string }).version ?? "unknown";
  let commit = "unknown";
  try {
    commit = execSync("git rev-parse --short HEAD", {
      cwd: new URL("..", import.meta.url).pathname,
      stdio: ["ignore", "pipe", "ignore"],
    })
      .toString()
      .trim() || "unknown";
  } catch {
    // not a git checkout (e.g. tarball install) → keep "unknown"
  }
  console.log(`batonq v${version} (commit ${commit})`);
  process.exit(0);
}

// ── check ─────────────────────────────────────────────────────────────────────

function check() {
  let green = true;
  const ok = (m: string) => console.log("  ok   " + m);
  const bad = (m: string) => {
    console.error("  FAIL " + m);
    green = false;
  };
  const warn = (m: string) => console.log("  warn " + m);

  if (existsSync(HOOK_PATH)) {
    const mode = statSync(HOOK_PATH).mode & 0o111;
    if (mode) ok(`hook binary executable: ${HOOK_PATH}`);
    else bad(`hook binary not executable: ${HOOK_PATH}`);
  } else bad(`hook binary missing: ${HOOK_PATH}`);

  if (existsSync(SETTINGS_PATH)) {
    try {
      const cfg = JSON.parse(readFileSync(SETTINGS_PATH, "utf8"));
      const pre = cfg.hooks?.PreToolUse ?? [];
      const post = cfg.hooks?.PostToolUse ?? [];
      const has = (arr: any[], pat: RegExp) =>
        arr.some((b: any) =>
          b.hooks?.some((h: any) => typeof h.command === "string" && pat.test(h.command))
        );
      if (has(pre, /(?:agent-coord-hook|batonq-hook)\s+pre\b/)) ok("PreToolUse hook (pre) configured");
      else bad("PreToolUse hook (pre) NOT configured");
      if (has(pre, /(?:agent-coord-hook|batonq-hook)\s+bash\b/)) ok("PreToolUse hook (bash) configured");
      else bad("PreToolUse hook (bash) NOT configured");
      if (has(post, /(?:agent-coord-hook|batonq-hook)\s+post\b/)) ok("PostToolUse hook (post) configured");
      else bad("PostToolUse hook (post) NOT configured");
    } catch (e: any) {
      bad(`could not parse settings.json: ${e.message}`);
    }
  } else bad(`settings.json missing: ${SETTINGS_PATH}`);

  if (!existsSync(LOG_DIR)) {
    try {
      mkdirSync(LOG_DIR, { recursive: true, mode: 0o700 });
      ok(`created log dir: ${LOG_DIR}`);
    } catch (e: any) {
      bad(`could not create log dir: ${e.message}`);
    }
  } else ok(`log dir exists: ${LOG_DIR}`);

  for (const [name, c] of [
    ["bun", "bun --version"],
    ["git", "git --version"],
  ] as const) {
    try {
      const v = execSync(c, { stdio: ["ignore", "pipe", "ignore"] }).toString().trim();
      ok(`${name}: ${v}`);
    } catch {
      bad(`${name} not on PATH`);
    }
  }
  try {
    const v = execSync("claude --version", { stdio: ["ignore", "pipe", "ignore"] })
      .toString()
      .trim();
    ok(`claude: ${v}`);
  } catch {
    warn("claude CLI version could not be detected (non-fatal)");
  }

  if (existsSync(LOG_PATH)) {
    ok(`events log: ${LOG_PATH} (${Math.round(statSync(LOG_PATH).size / 1024)} KB)`);
  } else warn(`events log not created yet — will appear on first in-scope tool call`);

  if (existsSync(DB_PATH)) {
    ok(`state.db: ${DB_PATH} (${Math.round(statSync(DB_PATH).size / 1024)} KB)`);
  } else warn(`state.db not created yet — will appear on first in-scope tool call`);

  process.exit(green ? 0 : 1);
}

// ── doctor ────────────────────────────────────────────────────────────────────
//
// `check` is the legacy single-pass health probe. `doctor` is the structured
// alternative: 5 categories (Binaries, Installation, State, Scope, Live), every
// row carries pass/warn/fail + an actionable `fix:` hint, and the closing
// summary lists every critical and warning so the output is copy-pastable into
// an issue. Diagnostic-only — never mutates state.

type DoctorStatus = "pass" | "warn" | "fail";
type DoctorCheck = { label: string; status: DoctorStatus; fix?: string };
type DoctorCategory = { name: string; checks: DoctorCheck[] };

function doctorSym(s: DoctorStatus): string {
  return s === "pass" ? "✓" : s === "warn" ? "⚠" : "✗";
}

function doctor(): void {
  const cats: DoctorCategory[] = [
    { name: "Binaries", checks: [] },
    { name: "Installation", checks: [] },
    { name: "State", checks: [] },
    { name: "Scope", checks: [] },
    { name: "Live", checks: [] },
  ];
  const add = (cat: string, label: string, status: DoctorStatus, fix?: string) => {
    const c = cats.find((x) => x.name === cat);
    if (!c) return;
    c.checks.push({ label, status, fix });
  };

  // ── 1. Binaries ─────────────────────────────────────────────────────────────
  // bun ≥ 1.0, git ≥ 2.0, jq ≥ 1.0 are hard requirements. claude is warn-only
  // because the queue itself works without it; only `enrich` and `batonq-loop`
  // need a Claude Code install.
  const binCheck = (name: string, cmd: string, minMajor: number, fix: string) => {
    try {
      const v = execSync(cmd, { stdio: ["ignore", "pipe", "ignore"] }).toString().trim();
      const m = v.match(/(\d+)\.(\d+)(?:\.(\d+))?/);
      if (m && parseInt(m[1] ?? "0", 10) >= minMajor) {
        add("Binaries", `${name}: ${v}`, "pass");
      } else {
        add("Binaries", `${name}: ${v} (need ≥ ${minMajor}.0)`, "fail", fix);
      }
    } catch {
      add("Binaries", `${name}: not found on PATH`, "fail", fix);
    }
  };
  binCheck("bun", "bun --version", 1, "curl -fsSL https://bun.sh/install | bash");
  binCheck("git", "git --version", 2, "install git via your package manager (brew install git / apt-get install git)");
  try {
    const v = execSync("claude --version", { stdio: ["ignore", "pipe", "ignore"] })
      .toString()
      .trim();
    add("Binaries", `claude: ${v}`, "pass");
  } catch {
    add(
      "Binaries",
      "claude: not found on PATH (optional — needed only for batonq-loop and `enrich`)",
      "warn",
      "install Claude Code: https://docs.claude.com/claude-code"
    );
  }
  binCheck("jq", "jq --version", 1, "brew install jq  (or: sudo apt-get install -y jq)");

  // ── 2. Installation ─────────────────────────────────────────────────────────
  // batonq must be on PATH and executable; the three install.sh-wired hook
  // matchers must be present in settings.json (PreToolUse pre, PreToolUse bash,
  // PostToolUse post); each hook command path must point at an executable.
  let batonqPath: string | null = null;
  try {
    batonqPath = execSync("command -v batonq", { stdio: ["ignore", "pipe", "ignore"] })
      .toString()
      .trim();
  } catch {
    batonqPath = null;
  }
  if (batonqPath) {
    add("Installation", `batonq on PATH: ${batonqPath}`, "pass");
    try {
      const mode = statSync(batonqPath).mode & 0o111;
      if (mode) add("Installation", `batonq has execute bit set`, "pass");
      else add("Installation", `batonq missing execute bit`, "fail", `chmod +x ${batonqPath}`);
    } catch (e: any) {
      add("Installation", `batonq stat failed: ${e.message}`, "fail");
    }
  } else {
    add(
      "Installation",
      `batonq not on PATH`,
      "fail",
      `add ~/.local/bin (or ~/bin) to PATH and re-run install.sh`
    );
  }

  if (!existsSync(SETTINGS_PATH)) {
    add(
      "Installation",
      `settings.json missing: ${SETTINGS_PATH}`,
      "fail",
      `re-run installer: curl -fsSL https://raw.githubusercontent.com/Salberg87/batonq/main/install.sh | sh`
    );
  } else {
    let cfg: any = null;
    try {
      cfg = JSON.parse(readFileSync(SETTINGS_PATH, "utf8"));
    } catch (e: any) {
      add(
        "Installation",
        `settings.json parse error: ${e.message}`,
        "fail",
        `fix the JSON at ${SETTINGS_PATH} (jq . ${SETTINGS_PATH} to locate)`
      );
    }
    if (cfg) {
      const hookRe = /(?:agent-coord-hook|batonq-hook)/;
      const hookPreRe = /(?:agent-coord-hook|batonq-hook)\s+pre\b/;
      const hookBashRe = /(?:agent-coord-hook|batonq-hook)\s+bash\b/;
      const hookPostRe = /(?:agent-coord-hook|batonq-hook)\s+post\b/;
      const has = (event: string, pat: RegExp) => {
        const arr = cfg.hooks?.[event] ?? [];
        return arr.some((b: any) =>
          (b.hooks ?? []).some((h: any) => typeof h.command === "string" && pat.test(h.command))
        );
      };
      if (has("PreToolUse", hookPreRe))
        add("Installation", `PreToolUse hook (pre, Read|Edit|Write|MultiEdit)`, "pass");
      else
        add(
          "Installation",
          `PreToolUse hook (pre) NOT configured`,
          "fail",
          `re-run install.sh — it merges hooks idempotently`
        );
      if (has("PreToolUse", hookBashRe))
        add("Installation", `PreToolUse hook (bash, Bash)`, "pass");
      else
        add(
          "Installation",
          `PreToolUse hook (bash) NOT configured`,
          "fail",
          `re-run install.sh`
        );
      if (has("PostToolUse", hookPostRe))
        add("Installation", `PostToolUse hook (post, Edit|Write|MultiEdit)`, "pass");
      else
        add(
          "Installation",
          `PostToolUse hook (post) NOT configured`,
          "fail",
          `re-run install.sh`
        );

      const hookPaths = new Set<string>();
      for (const evt of ["PreToolUse", "PostToolUse"]) {
        for (const block of cfg.hooks?.[evt] ?? []) {
          for (const h of block.hooks ?? []) {
            if (typeof h.command === "string" && hookRe.test(h.command)) {
              const m = h.command.trim().match(/^(\S+)/);
              if (m) hookPaths.add(m[1]);
            }
          }
        }
      }
      for (const hp of hookPaths) {
        const expanded = hp.replace(/^~/, HOME);
        if (!existsSync(expanded)) {
          add(
            "Installation",
            `hook binary missing: ${expanded}`,
            "fail",
            `re-run install.sh to (re)install batonq-hook`
          );
        } else {
          const mode = statSync(expanded).mode & 0o111;
          if (mode)
            add("Installation", `hook binary executable: ${expanded}`, "pass");
          else
            add(
              "Installation",
              `hook binary not executable: ${expanded}`,
              "fail",
              `chmod +x ${expanded}`
            );
        }
      }
    }
  }

  // ── 3. State ────────────────────────────────────────────────────────────────
  // state.db existence is informational (lazy-created by the hook), but if it
  // exists it must pass integrity_check and contain the three core tables.
  // TASKS.md must parse cleanly. events.jsonl directory must be writable.
  if (!existsSync(DB_PATH)) {
    add(
      "State",
      `state.db not created yet: ${DB_PATH}`,
      "warn",
      `make any tool call inside a repo under ~/DEV — the hook creates the db lazily`
    );
  } else {
    add(
      "State",
      `state.db exists: ${DB_PATH} (${Math.round(statSync(DB_PATH).size / 1024)} KB)`,
      "pass"
    );
    let db: Database | null = null;
    try {
      db = new Database(DB_PATH, { readonly: true });
      db.exec("PRAGMA busy_timeout=3000;");
      const integrity: any = db.query("PRAGMA integrity_check").get();
      const integrityOk = integrity?.integrity_check === "ok";
      if (integrityOk) add("State", `PRAGMA integrity_check: ok`, "pass");
      else
        add(
          "State",
          `PRAGMA integrity_check: ${JSON.stringify(integrity)}`,
          "fail",
          `back up ${DB_PATH} then delete it — the hook recreates it cleanly`
        );
      const tables = new Set(
        (db.query("SELECT name FROM sqlite_master WHERE type='table'").all() as any[]).map(
          (r) => r.name
        )
      );
      for (const t of ["sessions", "claims", "tasks"]) {
        if (tables.has(t)) add("State", `table '${t}' present`, "pass");
        else
          add(
            "State",
            `table '${t}' missing`,
            "fail",
            `delete ${DB_PATH} so the schema initialiser recreates it on next hook run`
          );
      }
    } catch (e: any) {
      add(
        "State",
        `could not open state.db: ${e.message}`,
        "fail",
        `check file permissions on ${DB_PATH}; back up and delete to recreate`
      );
    } finally {
      db?.close();
    }
  }

  // Path consistency: the rename bug left three DB files under `.claude/`.
  // Any legacy source still present after canonical-path install is a signal
  // that an older binary is still in the PATH writing to the stale file.
  const stray: string[] = [];
  for (const legacy of legacySources(HOME)) {
    if (existsSync(legacy)) stray.push(legacy);
  }
  if (stray.length === 0) {
    add("State", `DB path consistency: canonical ${DB_PATH} only`, "pass");
  } else {
    add(
      "State",
      `stale legacy DB(s) present: ${stray.join(", ")}`,
      "warn",
      `re-run install.sh to overwrite any stale binaries, then run 'batonq' once — migrate-path will back them up as *.legacy.bak`
    );
  }

  // Schema integrity: run the strict Zod schema across every task row. Rows
  // that fail are counted but not listed individually (a broken TASKS.md
  // parser can easily flag hundreds at once — listing them drowns out the
  // rest of the doctor report).
  if (existsSync(DB_PATH)) {
    let schemaDb: Database | null = null;
    try {
      schemaDb = new Database(DB_PATH, { readonly: true });
      schemaDb.exec("PRAGMA busy_timeout=3000;");
      const rows = schemaDb
        .query(
          `SELECT external_id, repo, body, status, priority, scheduled_for,
                  verify_cmd AS verify, judge_cmd AS judge
           FROM tasks`,
        )
        .all() as Array<Record<string, unknown>>;
      let invalid = 0;
      for (const r of rows) {
        // Skip null/undefined optionals so the schema's .optional() branches
        // apply instead of tripping on "not a string".
        const input: Record<string, unknown> = {
          external_id: r.external_id,
          repo: r.repo,
          body: r.body,
          status: r.status,
          priority: r.priority ?? "normal",
        };
        if (r.scheduled_for != null) input.scheduled_for = r.scheduled_for;
        if (r.verify != null) input.verify = r.verify;
        if (r.judge != null) input.judge = r.judge;
        try {
          parseTaskInput(input);
        } catch (e) {
          if (e instanceof ZodError) invalid++;
        }
      }
      if (rows.length === 0) {
        add("State", `schema integrity: 0 tasks to validate`, "pass");
      } else if (invalid === 0) {
        add(
          "State",
          `schema integrity: ${rows.length}/${rows.length} task(s) valid`,
          "pass",
        );
      } else {
        add(
          "State",
          `schema integrity: ${invalid}/${rows.length} task(s) fail Zod validation`,
          "warn",
          `inspect TASKS.md for short bodies, bad priority/status, or verify/judge stubs; re-sync with 'batonq sync-tasks'`,
        );
      }
    } catch (e: any) {
      add(
        "State",
        `schema integrity: could not scan tasks: ${e.message}`,
        "warn",
      );
    } finally {
      schemaDb?.close();
    }
  }

  if (!existsSync(TASKS_PATH)) {
    add(
      "State",
      `TASKS.md missing: ${TASKS_PATH}`,
      "fail",
      `mkdir -p ~/DEV && printf '## Pending\\n\\n' > ${TASKS_PATH}`
    );
  } else {
    try {
      const { tasks } = parseTasksFile();
      add("State", `TASKS.md parses cleanly (${tasks.length} task(s))`, "pass");
    } catch (e: any) {
      add(
        "State",
        `TASKS.md parse error: ${e.message}`,
        "fail",
        `inspect ${TASKS_PATH} for malformed task lines`
      );
    }
  }

  if (!existsSync(LOG_DIR)) {
    add(
      "State",
      `events log dir missing: ${LOG_DIR}`,
      "warn",
      `mkdir -p ${LOG_DIR}`
    );
  } else {
    // probe writability with an empty append; clean the probe up so we don't
    // leave litter beside the real log.
    const probe = `${LOG_DIR}/.batonq-doctor-probe`;
    try {
      writeFileSync(probe, "", { flag: "a" });
      try { unlinkSync(probe); } catch {}
      if (existsSync(LOG_PATH)) {
        add(
          "State",
          `events.jsonl append-able (${Math.round(statSync(LOG_PATH).size / 1024)} KB)`,
          "pass"
        );
      } else {
        add(
          "State",
          `events.jsonl not yet created (will appear on first hook run); dir is writable`,
          "pass"
        );
      }
    } catch (e: any) {
      add(
        "State",
        `events log dir not writable: ${e.message}`,
        "fail",
        `chmod u+w ${LOG_DIR}`
      );
    }
  }

  // ── 4. Scope ────────────────────────────────────────────────────────────────
  // The hook only fires inside a git repo whose toplevel sits under ~/DEV/ or
  // ~/dev/. Outside that the queue still works for `any:*` tasks but
  // repo-scoped tasks won't pick.
  let gitRoot: string | null = null;
  try {
    gitRoot = execSync("git rev-parse --show-toplevel", {
      stdio: ["ignore", "pipe", "ignore"],
    })
      .toString()
      .trim();
    if (!gitRoot) gitRoot = null;
  } catch {
    gitRoot = null;
  }
  if (!gitRoot) {
    add(
      "Scope",
      `cwd is not inside a git repo (${process.cwd()})`,
      "warn",
      `cd into a git repo under ~/DEV/ or ~/dev/ before running batonq-loop`
    );
  } else {
    const inDev =
      gitRoot.startsWith(`${HOME}/DEV/`) ||
      gitRoot === `${HOME}/DEV` ||
      gitRoot.startsWith(`${HOME}/dev/`) ||
      gitRoot === `${HOME}/dev`;
    if (inDev) add("Scope", `git-root inside ~/DEV: ${gitRoot}`, "pass");
    else
      add(
        "Scope",
        `git-root outside ~/DEV/ and ~/dev/: ${gitRoot}`,
        "warn",
        `move/clone the repo under ~/DEV/ or ~/dev/ to be picked up by repo-scoped tasks`
      );

    // Repo fingerprint: sha256(remote.origin.url + "|" + first-commit-SHA),
    // matching the hook's R10 invariant. No network call — pure git plumbing.
    try {
      const out = execSync(
        `git config --get remote.origin.url 2>/dev/null; echo "---"; git rev-list --max-parents=0 HEAD 2>/dev/null | head -1`,
        { cwd: gitRoot, stdio: ["ignore", "pipe", "ignore"], timeout: 1500, shell: "/bin/sh" }
      ).toString();
      const [remote, firstCommit] = out.split("---\n").map((s) => s.trim());
      if (remote && firstCommit) {
        const fp = createHash("sha256")
          .update(`${remote}|${firstCommit}`)
          .digest("hex")
          .slice(0, 16);
        add("Scope", `repo-fingerprint: ${fp}`, "pass");
      } else {
        add(
          "Scope",
          `repo-fingerprint: falls back to path (no remote or no commits)`,
          "warn",
          `git remote add origin <url> — fingerprint becomes stable across clones`
        );
      }
    } catch (e: any) {
      add("Scope", `repo-fingerprint compute failed: ${e.message}`, "warn");
    }
  }

  // ── 5. Live ─────────────────────────────────────────────────────────────────
  // Snapshot of running activity. Stale sessions (>10 min) and stuck claims
  // (>10 min) are warnings, not failures — they're recoverable.
  const STUCK_MS = 10 * 60_000;
  if (!existsSync(DB_PATH)) {
    add("Live", `no state.db yet — no live activity`, "pass");
  } else {
    let db: Database | null = null;
    try {
      db = new Database(DB_PATH, { readonly: true });
      db.exec("PRAGMA busy_timeout=3000;");
      const sessions = db
        .query("SELECT * FROM sessions ORDER BY last_seen DESC")
        .all() as any[];
      if (sessions.length === 0) {
        add("Live", `no active sessions`, "pass");
      } else {
        for (const s of sessions) {
          const ageS = Math.round((Date.now() - Date.parse(s.last_seen)) / 1000);
          if (ageS > 600) {
            add(
              "Live",
              `session ${s.session_id.slice(0, 12)} stale (last_seen ${ageS}s ago)`,
              "warn",
              `batonq sweep — purges sessions and claims past their TTL`
            );
          } else {
            add(
              "Live",
              `session ${s.session_id.slice(0, 12)} alive (last_seen ${ageS}s ago, cwd=${s.cwd ?? "?"})`,
              "pass"
            );
          }
        }
      }
      // Claims (file-locks) stuck > 10 min.
      const stuckClaims = db
        .query(
          `SELECT file_path, session_id, acquired_at FROM claims
           WHERE released_at IS NULL AND acquired_at < ?`
        )
        .all(new Date(Date.now() - STUCK_MS).toISOString()) as any[];
      if (stuckClaims.length === 0) {
        add("Live", `no file-claims stuck > 10 min`, "pass");
      } else {
        for (const c of stuckClaims) {
          const ageMin = Math.round((Date.now() - Date.parse(c.acquired_at)) / 60_000);
          add(
            "Live",
            `claim on ${c.file_path} held ${ageMin} min by ${c.session_id.slice(0, 12)}`,
            "warn",
            `batonq release ${c.file_path}  (or batonq sweep if owner is dead)`
          );
        }
      }
      // Task-level claims stuck > 10 min.
      const stuckTasks = db
        .query(
          `SELECT external_id, repo, claimed_by, claimed_at FROM tasks
           WHERE status = 'claimed' AND claimed_at < ?`
        )
        .all(new Date(Date.now() - STUCK_MS).toISOString()) as any[];
      if (stuckTasks.length === 0) {
        add("Live", `no task-claims stuck > 10 min`, "pass");
      } else {
        for (const t of stuckTasks) {
          const ageMin = Math.round((Date.now() - Date.parse(t.claimed_at)) / 60_000);
          add(
            "Live",
            `task ${t.external_id} [${t.repo}] held ${ageMin} min by ${t.claimed_by.slice(0, 12)}`,
            "warn",
            `batonq abandon ${t.external_id}  (re-queues it for another agent)`
          );
        }
      }
    } catch (e: any) {
      add(
        "Live",
        `could not query state.db: ${e.message}`,
        "fail",
        `see State category — db is broken`
      );
    } finally {
      db?.close();
    }
  }

  // ── Render ──────────────────────────────────────────────────────────────────
  let total = 0;
  let passed = 0;
  const critical: string[] = [];
  const warnings: string[] = [];
  for (const c of cats) {
    console.log(`\n${c.name}:`);
    for (const ck of c.checks) {
      total++;
      if (ck.status === "pass") passed++;
      else if (ck.status === "fail") critical.push(`${c.name}: ${ck.label}`);
      else warnings.push(`${c.name}: ${ck.label}`);
      console.log(`  ${doctorSym(ck.status)} ${ck.label}`);
      if (ck.fix && ck.status !== "pass") {
        console.log(`      fix: ${ck.fix}`);
      }
    }
  }

  console.log();
  console.log(`Summary — batonq doctor: ${passed}/${total} checks passed.`);
  if (critical.length === 0) {
    console.log(`Critical: []`);
  } else {
    console.log(`Critical: [${critical.length}]`);
    for (const c of critical) console.log(`  - ${c}`);
  }
  if (warnings.length === 0) {
    console.log(`Warnings: []`);
  } else {
    console.log(`Warnings: [${warnings.length}]`);
    for (const w of warnings) console.log(`  - ${w}`);
  }

  process.exit(critical.length === 0 ? 0 : 1);
}

// ── tail ──────────────────────────────────────────────────────────────────────

function tail() {
  const nIdx = process.argv.indexOf("-n");
  const n = nIdx > 0 ? parseInt(process.argv[nIdx + 1] ?? "50", 10) || 50 : 50;
  if (!existsSync(LOG_PATH)) {
    console.log("(no events yet)");
    return;
  }
  const lines = readFileSync(LOG_PATH, "utf8").trim().split("\n").slice(-n);
  for (const l of lines) {
    let e: any;
    try {
      e = JSON.parse(l);
    } catch {
      continue;
    }
    const repo = e.git_root ? basename(e.git_root) : "?";
    const rel = (e.paths ?? [])
      .map((p: string) => (e.git_root ? p.replace(e.git_root + "/", "") : p))
      .join(", ");
    const pat = e.bash_pattern ? ` [${e.bash_pattern}]` : "";
    console.log(
      `${e.ts.slice(11, 19)}  ${String(e.session).slice(0, 8)}  ${e.tool.padEnd(9)} ${e.phase.padEnd(4)} ${repo}/${rel}${pat}`
    );
  }
}

// ── logs ──────────────────────────────────────────────────────────────────────
// Combined tail over events.jsonl (hook events) + loop stdout
// (/tmp/batonq-loop*.log, newest). Lines are merged stably by timestamp and
// painted: events=cyan, loop=yellow, error-ish lines=red.
//
// Flags:
//   --follow / -f              tail -f-style streaming (500ms poll)
//   -n <N>                     last N merged lines (default 20)
//   --source events|loop|both  filter by source (default both)

async function logs(): Promise<void> {
  const args = process.argv.slice(3);
  const follow = args.includes("-f") || args.includes("--follow");

  let n = 20;
  const nIdx = args.findIndex((a) => a === "-n");
  if (nIdx >= 0 && args[nIdx + 1]) {
    const parsed = parseInt(args[nIdx + 1], 10);
    if (Number.isFinite(parsed) && parsed > 0) n = parsed;
  }

  let source: "events" | "loop" | "both" = "both";
  const sIdx = args.findIndex((a) => a === "--source");
  if (sIdx >= 0 && args[sIdx + 1]) {
    const s = args[sIdx + 1];
    if (s === "events" || s === "loop" || s === "both") {
      source = s;
    } else {
      console.error(`invalid --source: ${s} (expected events|loop|both)`);
      process.exit(2);
    }
  }

  const {
    readEvents,
    readLoop,
    newestLoopLog,
    mergeAndTail,
    colorize,
    formatEventLine,
    classifyLoopLine,
  } = require("./logs-core");

  const useColor = !!process.stdout.isTTY && process.env.NO_COLOR == null;

  // ── one-shot: last N merged lines ────────────────────────────────────────
  const events = source === "loop" ? [] : readEvents(LOG_PATH);
  let loopPath: string | null =
    source === "events" ? null : newestLoopLog(LOOP_LOG_GLOB);
  const loop = source === "events" ? [] : readLoop(loopPath);
  const merged = mergeAndTail(events, loop, { source, n });
  for (const r of merged) console.log(colorize(r, useColor));

  if (!follow) return;

  // ── follow mode: byte-offset tail with 500ms polling ─────────────────────
  // We anchor on byte offsets (not line counts) so mid-write appends don't
  // duplicate. On truncation (size shrinks) we reset to 0 and start over.
  // For events.jsonl we only emit whole lines; a trailing partial stays in
  // the pending buffer until its newline arrives.
  let evOffset = existsSync(LOG_PATH) ? statSync(LOG_PATH).size : 0;
  let evPending = "";
  let loopOffset = loopPath && existsSync(loopPath) ? statSync(loopPath).size : 0;
  let loopPending = "";

  const readTail = async (path: string, from: number, to: number): Promise<string> => {
    // Bun.file().slice() returns a Blob for a byte range — no full re-read.
    return await Bun.file(path).slice(from, to).text();
  };

  const pollOnce = async (): Promise<void> => {
    // Rotation: the newest matching loop log may have changed (or appeared).
    if (source !== "events") {
      const current = newestLoopLog(LOOP_LOG_GLOB);
      if (current !== loopPath) {
        loopPath = current;
        loopOffset = 0;
        loopPending = "";
      }
    }

    if (source !== "loop" && existsSync(LOG_PATH)) {
      const size = statSync(LOG_PATH).size;
      if (size < evOffset) {
        evOffset = 0;
        evPending = "";
      }
      if (size > evOffset) {
        const chunk = await readTail(LOG_PATH, evOffset, size);
        evOffset = size;
        const text = evPending + chunk;
        const lastNl = text.lastIndexOf("\n");
        const complete = lastNl >= 0 ? text.slice(0, lastNl) : "";
        evPending = lastNl >= 0 ? text.slice(lastNl + 1) : text;
        for (const raw of complete.split("\n")) {
          if (!raw.trim()) continue;
          const f = formatEventLine(raw);
          if (!f) continue;
          console.log(
            colorize(
              { ts: f.ts, source: "events", line: f.line, level: f.level },
              useColor,
            ),
          );
        }
      }
    }

    if (source !== "events" && loopPath && existsSync(loopPath)) {
      const size = statSync(loopPath).size;
      if (size < loopOffset) {
        loopOffset = 0;
        loopPending = "";
      }
      if (size > loopOffset) {
        const chunk = await readTail(loopPath, loopOffset, size);
        loopOffset = size;
        const text = loopPending + chunk;
        const lastNl = text.lastIndexOf("\n");
        const complete = lastNl >= 0 ? text.slice(0, lastNl) : "";
        loopPending = lastNl >= 0 ? text.slice(lastNl + 1) : text;
        for (const line of complete.split("\n")) {
          if (line.length === 0) continue;
          console.log(
            colorize(
              {
                ts: Date.now(),
                source: "loop",
                line,
                level: classifyLoopLine(line),
              },
              useColor,
            ),
          );
        }
      }
    }
  };

  // Poll forever — SIGINT (Ctrl-C) will terminate the process naturally.
  // eslint-disable-next-line no-constant-condition
  while (true) {
    await new Promise((r) => setTimeout(r, LOGS_POLL_MS));
    try {
      await pollOnce();
    } catch {
      // Any transient FS error: swallow and keep polling. Rotation, truncation,
      // and race conditions already have explicit paths above.
    }
  }
}

// ── status ────────────────────────────────────────────────────────────────────

function status() {
  if (!existsSync(DB_PATH)) {
    console.log("(no state.db yet — no activity)");
    return;
  }
  const db = new Database(DB_PATH, { readonly: true });
  db.exec("PRAGMA busy_timeout=3000;");
  const sessions = db
    .query("SELECT * FROM sessions ORDER BY last_seen DESC")
    .all() as any[];
  console.log(`Sessions (${sessions.length}):`);
  for (const s of sessions) {
    const ageS = Math.round((Date.now() - Date.parse(s.last_seen)) / 1000);
    const stale = ageS > 600 ? " STALE" : "";
    console.log(`  ${s.session_id.slice(0, 10)}  cwd=${s.cwd}  last_seen=${ageS}s ago${stale}`);
  }
  console.log();
  const claims = db
    .query(
      `SELECT c.*, s.cwd FROM claims c
       LEFT JOIN sessions s ON s.session_id = c.session_id
       WHERE c.released_at IS NULL
       ORDER BY c.acquired_at`
    )
    .all() as any[];
  console.log(`Active claims (${claims.length}):`);
  for (const c of claims) {
    const ageS = Math.round((Date.now() - Date.parse(c.acquired_at)) / 1000);
    const expS = Math.round((Date.parse(c.expires_at) - Date.now()) / 1000);
    console.log(
      `  ${c.file_path}  →  ${c.session_id.slice(0, 10)}  (held ${ageS}s, expires in ${expS}s)`
    );
  }
  db.close();
}

// ── release ───────────────────────────────────────────────────────────────────

function release(path: string | undefined) {
  if (!path) {
    console.error("usage: batonq release <path>");
    process.exit(2);
  }
  if (!existsSync(DB_PATH)) {
    console.log("(no state.db — nothing to release)");
    return;
  }
  const abs = isAbsolute(path) ? path : resolve(process.cwd(), path);
  const db = new Database(DB_PATH);
  db.exec("PRAGMA busy_timeout=3000;");
  const r = db.run(
    `UPDATE claims SET released_at = ? WHERE file_path = ? AND released_at IS NULL`,
    [new Date().toISOString(), abs]
  );
  console.log(`Released ${r.changes} active claim(s) on ${abs}`);
  db.close();
}

// ── sweep ─────────────────────────────────────────────────────────────────────

function sweepCmd() {
  if (!existsSync(DB_PATH)) {
    console.log("(no state.db — nothing to sweep)");
    return;
  }
  const db = new Database(DB_PATH);
  db.exec("PRAGMA busy_timeout=3000;");
  const now = new Date().toISOString();
  const expired = db.run(
    `UPDATE claims SET released_at = ? WHERE released_at IS NULL AND expires_at < ?`,
    [now, now]
  );
  const cutoff = new Date(Date.now() - 30 * 60_000).toISOString();
  const staleS = db.run(`DELETE FROM sessions WHERE last_seen < ?`, [cutoff]);
  console.log(`Swept: ${expired.changes} expired claim(s), ${staleS.changes} stale session(s).`);
  db.close();
}

// sweep-tasks: distinct from `sweep` (which releases file-claims and expires
// sessions). Walks claimed tasks whose last progress predates the TTL, runs
// the recovery hook on each, and either defers live-but-quiet holders or
// flips dead holders to status=lost and appends an escalation log line.
function sweepTasksCmd() {
  if (!existsSync(DB_PATH)) {
    console.log("(no state.db — nothing to sweep)");
    return;
  }
  const db = openTaskDb();
  try {
    const res = sweepTasksCore(db);
    console.log(
      `Swept tasks: ${res.lost} lost, ${res.deferred} deferred (scanned ${res.scanned}).`
    );
  } finally {
    db.close();
  }
}

// ── tasks ─────────────────────────────────────────────────────────────────────

function parseTasksFile(): { lines: string[]; tasks: ParsedTask[] } {
  return parseTasksFileCore(TASKS_PATH);
}

function openTaskDb(): Database {
  // DB_PATH is directory-based; ensure the parent dir exists before bun:sqlite
  // tries to create the file. mkdirSync is a no-op when the dir already exists
  // so callers don't need to gate on existsSync.
  mkdirSync(DB_DIR, { recursive: true });
  const db = new Database(DB_PATH, { create: true });
  db.exec("PRAGMA busy_timeout=3000;");
  initTaskSchema(db);
  // sweepTasks (and anything else that joins against sessions for liveness)
  // needs the sessions/claims tables even if the hook has never run in this
  // $HOME yet. Keeping the schema init colocated with openTaskDb makes the
  // CLI self-sufficient on a fresh install.
  initClaimsSchema(db);
  return db;
}

function syncTasks(verbose: boolean): { added: number; completed: number; parsed: number } {
  const { tasks: parsed } = parseTasksFile();
  const db = openTaskDb();
  let result;
  try {
    result = syncTasksCore(db, parsed);
  } finally {
    db.close();
  }
  if (verbose) {
    console.log(
      `Synced ${result.parsed} task(s) from ${TASKS_PATH}: ${result.added} new, ${result.completed} newly marked done.`
    );
  }
  return result;
}

function getRepoForCwd(): string | null {
  try {
    const root = execSync("git rev-parse --show-toplevel", {
      stdio: ["ignore", "pipe", "ignore"],
    })
      .toString()
      .trim();
    return root ? basename(root) : null;
  } catch {
    return null;
  }
}

function currentSession(): string {
  // Session identifier per terminal: TTY + shell PID.
  // Not Claude's session_id (not available here), but stable within a single Warp tab's lifetime.
  try {
    const tty = execSync("tty", { stdio: ["ignore", "pipe", "ignore"] })
      .toString()
      .trim()
      .replace("/dev/", "");
    return `term_${tty}_${process.ppid}`;
  } catch {
    return `pid_${process.ppid}`;
  }
}

function pickTask(): void {
  // DB is now the single source of truth for tasks. `batonq sync-tasks` is
  // still available as an explicit one-shot import from TASKS.md, but the
  // pick hot path no longer re-parses the file — it trusts the DB.
  const db = openTaskDb();
  try {
    // Auto-sweep task-TTLs before picking so stale claims don't block the
    // queue. Keeps the sweep hot path inline with pick instead of relying
    // on a cron — the most reliable trigger is "another agent wants work".
    sweepTasksCore(db);

    // Audit queue for deadlock-prone verify_cmds (`git log -1 | grep ...`) so
    // operators can rewrite them before the race bites. Runs once per pick;
    // cheap and silent when the queue is clean.
    const fragile = db
      .query(
        `SELECT external_id, verify_cmd FROM tasks
           WHERE status IN ('pending','claimed','draft') AND verify_cmd IS NOT NULL`
      )
      .all() as Array<{ external_id: string; verify_cmd: string }>;
    const flagged = fragile.filter((t) => detectFragileGitLog(t.verify_cmd));
    if (flagged.length > 0) {
      console.error(
        `⚠ ${flagged.length} queued task(s) use fragile \`git log -1 | grep\` in verify — ` +
          `switch to \`git_commits_since_claim\` (see docs/faq.md). Affected: ` +
          flagged.map((t) => t.external_id).join(", ")
      );
    }

    const repo = getRepoForCwd();
    const session = currentSession();
    const args = process.argv.slice(3);
    const any = args.includes("--any");

    const candidate: any = selectCandidate(db, { repo, any });
    if (!candidate) {
      console.log("NO_TASK");
      if (any) {
        console.log(`No pending tasks in the queue at ${TASKS_PATH}`);
      } else if (repo) {
        console.log(`No pending tasks for repo "${repo}" (or any:* tasks). Queue: ${TASKS_PATH}`);
      } else {
        console.log(
          `No pending any:* tasks (current cwd is not in a git-repo; use --any to pick any task, or cd into a repo).`
        );
      }
      return;
    }
    const result = claimCandidate(db, candidate.id, session);
    if (result.changes === 0) {
      console.log("NO_TASK");
      console.log("Task was claimed by another session between sync and claim. Run /pick-next again.");
      return;
    }
    console.log(`TASK_CLAIMED`);
    console.log(`external_id: ${candidate.external_id}`);
    console.log(`repo:        ${candidate.repo}`);
    console.log(`priority:    ${candidate.priority ?? "normal"}`);
    if (candidate.scheduled_for) {
      console.log(`scheduled:   ${candidate.scheduled_for}`);
    }
    console.log(`session:     ${session}`);
    console.log(``);
    console.log(`TASK:`);
    console.log(candidate.body);
    console.log(``);
    console.log(`When complete:   batonq done ${candidate.external_id}`);
    console.log(`If abandoning:   batonq abandon ${candidate.external_id}`);
  } finally {
    db.close();
  }
}

function mineTask(): void {
  const db = openTaskDb();
  const session = currentSession();
  const mine = db
    .query(`SELECT * FROM tasks WHERE status = 'claimed' AND claimed_by = ? ORDER BY claimed_at`)
    .all(session) as any[];
  const others = db
    .query(`SELECT * FROM tasks WHERE status = 'claimed' AND claimed_by != ? ORDER BY claimed_at`)
    .all(session) as any[];
  const prioBadge = (p: string | null | undefined) =>
    p === "high" ? "[H]" : p === "low" ? "[L]" : "[N]";
  console.log(`My claims (${mine.length}) — session ${session}:`);
  for (const r of mine) {
    const ageS = Math.round((Date.now() - Date.parse(r.claimed_at)) / 1000);
    console.log(
      `  ${r.external_id}  ${prioBadge(r.priority)} [${r.repo}] ${r.body}  (${ageS}s ago)`,
    );
  }
  if (others.length) {
    console.log();
    console.log(`Other sessions' claims (${others.length}):`);
    for (const r of others) {
      const ageS = Math.round((Date.now() - Date.parse(r.claimed_at)) / 1000);
      console.log(
        `  ${r.external_id}  ${prioBadge(r.priority)} [${r.repo}] ${r.body}  — ${r.claimed_by}  (${ageS}s ago)`,
      );
    }
  }
  db.close();
}

function resolveRepoPath(repoName: string): string {
  if (repoName.startsWith("any:")) return process.cwd();
  for (const base of [`${HOME}/DEV`, `${HOME}/dev`]) {
    const p = `${base}/${repoName}`;
    if (existsSync(p)) {
      try {
        execSync("git rev-parse --show-toplevel", {
          cwd: p,
          stdio: ["ignore", "ignore", "ignore"],
          timeout: 1000,
        });
        return p;
      } catch {
        // not a git repo, keep looking
      }
    }
  }
  return process.cwd();
}

// Thin wrappers so the hardening invariant stays discoverable at the call-site
// in this file. Both delegate to tasks-core where the logic is unit-tested
// (see tests/core.test.ts → "runJudge fail-modes", "getGitDiffSinceClaim fail-modes").
function runJudge(judgePrompt: string, gitDiff: string, cwd: string): { passed: boolean; output: string } {
  // Invariant: PASS requires result.status === 0 && !result.error FIRST —
  // never trust stdout alone. ETIMEDOUT and other spawn errors → infra FAIL.
  return runJudgeCore(judgePrompt, gitDiff, cwd);
}

function getGitDiffSinceClaim(cwd: string, claimedAt: string): string {
  // Throws on any failure (git error, empty diff). doneTask catches the
  // throw and surfaces a judge FAIL — we must NEVER feed an empty diff
  // to the LLM (it typically answers PASS and the gate fail-opens).
  return getGitDiffSinceClaimCore(cwd, claimedAt);
}

function doneTask(id?: string): void {
  const args = process.argv.slice(3);
  // --skip-verify / --skip-judge removed 2026-04-23. The AGENT_COORD_ALLOW_SKIP env
  // gate was self-settable by the caller (agents just exported it), so it did not
  // actually protect the queue. Gates are now mandatory; fix the issue or abandon.
  if (args.includes("--skip-verify") || args.includes("--skip-judge")) {
    console.error("--skip-verify / --skip-judge are no longer accepted. Gates are mandatory.");
    console.error("If verify/judge fails, fix the underlying issue or run: batonq abandon <id>");
    process.exit(2);
  }
  const positional = args.filter((a) => !a.startsWith("--"));
  const explicitId = positional[0];
  const db = openTaskDb();
  try {
    const session = currentSession();
    let target: any;
    if (explicitId ?? id) {
      const wanted = explicitId ?? id;
      target = db.query("SELECT * FROM tasks WHERE external_id = ?").get(wanted);
      if (!target) {
        console.error(`No task with external_id ${wanted}.`);
        process.exit(1);
      }
    } else {
      target = db
        .query(
          `SELECT * FROM tasks WHERE status = 'claimed' AND claimed_by = ? ORDER BY claimed_at DESC LIMIT 1`
        )
        .get(session);
      if (!target) {
        console.error(`No claimed task for this session. Pass the external_id explicitly.`);
        process.exit(1);
      }
    }

    // --- Verify gate (mandatory since 2026-04-23) ---
    if (target.verify_cmd) {
      const repoPath = resolveRepoPath(target.repo);
      console.log(`→ verify: ${target.verify_cmd}`);
      console.log(`  (cwd: ${repoPath}, timeout: 300s)`);
      console.log();
      // target.claimed_at is plumbed through so runVerify can export it as
      // BATONQ_CLAIM_TS — verify scripts should assert on commits since the
      // claim (git_commits_since_claim), not `git log -1`, which flakes when
      // a peer loop commits between done and the gate. See docs/faq.md.
      const { code, output } = runVerify(target.verify_cmd, repoPath, target.external_id, target.claimed_at);
      const truncated = output.length > 80_000 ? output.slice(0, 80_000) + "\n[truncated]" : output;
      process.stdout.write(truncated);
      console.log();
      db.run(
        `UPDATE tasks SET verify_output = ?, verify_ran_at = ? WHERE id = ?`,
        [truncated, new Date().toISOString(), target.id]
      );
      if (code !== 0) {
        console.error(`✗ verify FAILED (exit ${code}). Task stays claimed.`);
        console.error(`  Fix the underlying issue and retry: batonq done ${target.external_id}`);
        console.error(`  Or release and re-queue: batonq abandon ${target.external_id}`);
        process.exit(code);
      }
      console.log(`✓ verify passed.`);
    }

    // --- Judge gate (mandatory since 2026-04-23) ---
    if (target.judge_cmd) {
      const repoPath = resolveRepoPath(target.repo);
      console.log(`→ judge: ${target.judge_cmd}`);
      console.log(`  (cwd: ${repoPath})`);
      console.log();

      let gitDiff: string;
      try {
        gitDiff = getGitDiffSinceClaim(repoPath, target.claimed_at);
      } catch (e: any) {
        const msg = `[judge FAIL] ${e?.message ?? String(e)}`;
        console.error(msg);
        db.run(
          `UPDATE tasks SET judge_output = ?, judge_ran_at = ? WHERE id = ?`,
          [msg, new Date().toISOString(), target.id]
        );
        console.error(`✗ judge FAILED. Task stays claimed.`);
        console.error(`  Fix issues and retry: batonq done ${target.external_id}`);
        console.error(`  Or release and re-queue: batonq abandon ${target.external_id}`);
        process.exit(1);
      }

      const { passed, output } = runJudge(target.judge_cmd, gitDiff, repoPath);

      const truncated = output.length > 80_000 ? output.slice(0, 80_000) + "\n[truncated]" : output;
      process.stdout.write(truncated);
      console.log();

      db.run(
        `UPDATE tasks SET judge_output = ?, judge_ran_at = ? WHERE id = ?`,
        [truncated, new Date().toISOString(), target.id]
      );

      if (!passed) {
        console.error(`✗ judge FAILED. Task stays claimed.`);
        console.error(`  Fix issues and retry: batonq done ${target.external_id}`);
        console.error(`  Or release and re-queue: batonq abandon ${target.external_id}`);
        process.exit(1);
      }
      console.log(`✓ judge passed.`);
    }

    db.run(
      `UPDATE tasks SET status = 'done', completed_at = ? WHERE id = ?`,
      [new Date().toISOString(), target.id]
    );
    rewriteMdTaskStatus(target.repo, target.body, "done");
    console.log(`✓ done: [${target.repo}] ${target.body}`);
  } finally {
    db.close();
  }
}

function abandonTask(id?: string): void {
  const db = openTaskDb();
  try {
    const session = currentSession();
    let target: any;
    if (id) {
      target = db.query("SELECT * FROM tasks WHERE external_id = ?").get(id);
    } else {
      target = db
        .query(
          `SELECT * FROM tasks WHERE status = 'claimed' AND claimed_by = ? ORDER BY claimed_at DESC LIMIT 1`
        )
        .get(session);
    }
    if (!target) {
      console.error("No matching task.");
      process.exit(1);
    }
    db.run(
      `UPDATE tasks SET status = 'pending', claimed_by = NULL, claimed_at = NULL WHERE id = ?`,
      [target.id]
    );
    console.log(`↺ abandoned (re-queued): [${target.repo}] ${target.body}`);
  } finally {
    db.close();
  }
}

function listTasks(): void {
  // DB-first: `tasks` reads straight from the DB. If the user has edited
  // TASKS.md and wants the changes to show up, they run `batonq sync-tasks`
  // explicitly (or use `batonq add` / `batonq import` instead).
  const db = openTaskDb();
  const now = new Date().toISOString();
  const groups: Array<["pending" | "claimed" | "done", string]> = [
    ["pending", "Pending"],
    ["claimed", "Claimed"],
    ["done", "Done (recent)"],
  ];
  for (const [status, label] of groups) {
    // Pending rows are listed in the same order pick() consumes them (priority,
    // ripe scheduled_for, then created_at) so this view is a faithful preview
    // of the next claims. Claimed + done keep their existing order.
    const query =
      status === "done"
        ? `SELECT * FROM tasks WHERE status = ? ORDER BY completed_at DESC LIMIT 10`
        : status === "pending"
          ? `SELECT * FROM tasks WHERE status = ?
             ORDER BY
               CASE priority WHEN 'high' THEN 0 WHEN 'normal' THEN 1 ELSE 2 END ASC,
               COALESCE(scheduled_for, created_at) ASC,
               created_at ASC`
          : `SELECT * FROM tasks WHERE status = ? ORDER BY id`;
    const rows = db.query(query).all(status) as any[];
    if (rows.length === 0) continue;
    console.log(`${label} (${rows.length}):`);
    for (const r of rows) {
      const prio = r.priority ?? "normal";
      const prioBadge =
        prio === "high" ? "[H]" : prio === "low" ? "[L]" : "[N]";
      const schedBadge = r.scheduled_for
        ? r.scheduled_for > now
          ? ` ⏰${r.scheduled_for}`
          : ` ⏰(ripe)`
        : "";
      const claimBadge =
        status === "claimed" && r.claimed_by
          ? `  [claimed by ${r.claimed_by.slice(0, 12)}]`
          : "";
      console.log(
        `  ${r.external_id}  ${prioBadge} [${r.repo}] ${r.body}${schedBadge}${claimBadge}`,
      );
    }
    console.log();
  }
  db.close();
}

function rewriteMdTaskStatus(repo: string, body: string, newStatus: "done" | "pending"): void {
  rewriteMdTaskStatusCore(TASKS_PATH, repo, body, newStatus);
}

// ── add / import / export ─────────────────────────────────────────────────────
//
// DB-first input path. `add` takes a single task via flags (or JSON on stdin);
// `import` takes a YAML / markdown file; `export --md` writes the DB back out
// as a read-only snapshot. These replace TASKS.md as the canonical input
// surface — the old file becomes an optional one-way import target.

interface AddFlags {
  body?: string;
  repo?: string;
  verify?: string;
  judge?: string;
  priority: string;
  at?: string;
  status?: string;
  agent?: string;
  json: boolean;
}

function parseAddFlags(args: string[]): AddFlags {
  const flags: AddFlags = { priority: "normal", json: false };
  for (let i = 0; i < args.length; i++) {
    const a = args[i]!;
    const takeNext = (label: string): string => {
      const v = args[++i];
      if (v == null) {
        console.error(`${label} requires a value`);
        process.exit(2);
      }
      return v;
    };
    switch (a) {
      case "--body":
        flags.body = takeNext("--body");
        break;
      case "--repo":
        flags.repo = takeNext("--repo");
        break;
      case "--verify":
        flags.verify = takeNext("--verify");
        break;
      case "--judge":
        flags.judge = takeNext("--judge");
        break;
      case "--priority":
        flags.priority = takeNext("--priority");
        break;
      case "--at":
        flags.at = takeNext("--at");
        break;
      case "--status":
        flags.status = takeNext("--status");
        break;
      case "--agent":
        flags.agent = takeNext("--agent");
        break;
      case "--json":
        flags.json = true;
        break;
      default:
        console.error(`add: unknown flag: ${a}`);
        console.error(
          "usage: batonq add --body <text> [--repo <name>] [--verify <sh>] [--judge <prompt>] [--priority high|normal|low] [--at <ISO>] [--status draft|pending] [--agent claude|codex|gemini|opencode|any] [--json]",
        );
        process.exit(2);
    }
  }
  return flags;
}

function addCmd(): void {
  const args = process.argv.slice(3);
  const flags = parseAddFlags(args);

  // Build the input object. In --json mode we start from stdin (a complete
  // task object) and let any explicit flags override individual fields. In
  // flag mode --body is required up front.
  let input: Record<string, unknown>;
  if (flags.json) {
    const stdin = readFileSync(0, "utf8");
    if (!stdin.trim()) {
      console.error("--json: empty stdin (expected a JSON object)");
      process.exit(1);
    }
    try {
      const parsed = JSON.parse(stdin);
      if (!parsed || typeof parsed !== "object" || Array.isArray(parsed)) {
        console.error("--json: stdin must be a JSON object");
        process.exit(1);
      }
      input = parsed as Record<string, unknown>;
    } catch (e: any) {
      console.error(`--json: invalid JSON on stdin: ${e.message}`);
      process.exit(1);
    }
  } else {
    if (!flags.body) {
      console.error("add: --body is required (or pass --json and pipe a JSON object on stdin)");
      process.exit(2);
    }
    input = {};
  }

  if (flags.body !== undefined) input.body = flags.body;
  if (flags.repo !== undefined) input.repo = flags.repo;
  if (flags.verify !== undefined) input.verify = flags.verify;
  if (flags.judge !== undefined) input.judge = flags.judge;
  // Only write priority when it was explicitly passed on the CLI, so
  // --json payloads can set their own priority without getting clobbered.
  if (args.includes("--priority")) input.priority = flags.priority;
  if (flags.at !== undefined) input.scheduled_for = flags.at;
  if (flags.status !== undefined) input.status = flags.status;
  if (flags.agent !== undefined) input.agent = flags.agent;

  // Derive repo from the cwd git-root when neither flags nor JSON supplied one.
  if (!("repo" in input) || !input.repo) {
    const repo = getRepoForCwd();
    input.repo = repo ?? "any:infra";
  }

  const db = openTaskDb();
  try {
    const eid = validatedInsertTask(db, input);
    // Drop the deprecation header onto TASKS.md the first time someone uses
    // the new DB-first path. Best-effort — a read-only FS or missing file is
    // fine to ignore.
    try {
      ensureTasksMdDeprecationHeader(TASKS_PATH);
    } catch {
      /* non-fatal */
    }
    console.log(`task added: ${eid}`);
  } catch (e: any) {
    if (e instanceof ZodError) {
      console.error("add: schema validation failed");
      for (const issue of e.issues) {
        const path = issue.path.join(".") || "(root)";
        console.error(`  ${path}: ${issue.message}`);
      }
      process.exit(1);
    }
    if (e instanceof DuplicateExternalIdError) {
      console.error(`add: duplicate external_id ${e.externalId} — task already in DB`);
      process.exit(1);
    }
    console.error(`add failed: ${e?.message ?? String(e)}`);
    process.exit(1);
  } finally {
    db.close();
  }
}

function importCmd(file?: string): void {
  if (!file) {
    console.error("usage: batonq import <file.yaml|file.md>");
    process.exit(2);
  }
  if (!existsSync(file)) {
    console.error(`import: file not found: ${file}`);
    process.exit(1);
  }
  const text = readFileSync(file, "utf8");
  const format = detectImportFormat(file, text);

  let raws: unknown[];
  try {
    raws =
      format === "yaml" ? parseYamlTasksText(text) : parseMarkdownTasksForImport(text);
  } catch (e: any) {
    console.error(`import: parse error (${format}): ${e.message}`);
    process.exit(1);
  }

  const db = openTaskDb();
  let report;
  try {
    report = runImport(db, raws);
  } finally {
    db.close();
  }

  // Persist the per-entry log so the user has a concrete artifact to inspect
  // on anything other than a clean run. `/tmp` is the right place here: logs
  // are session-scoped and a disappearing tmpfs is fine.
  const logfile = `/tmp/batonq-import-${Date.now()}.log`;
  if (report.logLines.length > 0) {
    try {
      writeFileSync(logfile, report.logLines.join("\n") + "\n", { mode: 0o600 });
    } catch {
      /* non-fatal */
    }
  }

  try {
    ensureTasksMdDeprecationHeader(TASKS_PATH);
  } catch {
    /* non-fatal */
  }

  const parts: string[] = [`imported ${report.imported} tasks`];
  const issues: string[] = [];
  if (report.invalid > 0) issues.push(`${report.invalid} invalid`);
  if (report.duplicates > 0) issues.push(`${report.duplicates} duplicate`);
  if (issues.length > 0) {
    parts.push(`(${issues.join(", ")} — see ${logfile})`);
  }
  console.log(parts.join(" "));
  // Exit non-zero if ANY entry failed validation so CI / scripts can detect
  // a partial import. Duplicates alone are not an error — insert-new semantics.
  if (report.invalid > 0) process.exit(1);
}

function exportCmd(): void {
  const args = process.argv.slice(3);
  // --md is the only supported format right now but keep it explicit so
  // future flags (--json, --csv) have a clean slot.
  const wantsMd = args.includes("--md");
  const fileIdx = args.indexOf("--file");
  const file = fileIdx >= 0 ? args[fileIdx + 1] : undefined;
  const unknown = args.filter((a, i) => {
    if (a === "--md") return false;
    if (a === "--file") return false;
    if (i > 0 && args[i - 1] === "--file") return false;
    return true;
  });
  if (unknown.length > 0) {
    console.error(`export: unknown flag(s): ${unknown.join(" ")}`);
    console.error("usage: batonq export --md [--file PATH]");
    process.exit(2);
  }
  if (!wantsMd) {
    console.error("export: --md is required (no other formats supported yet)");
    console.error("usage: batonq export --md [--file PATH]");
    process.exit(2);
  }
  const db = openTaskDb();
  try {
    const content = exportTasksAsMarkdown(db);
    if (file) {
      writeFileSync(file, content);
      console.log(`exported to ${file}`);
    } else {
      process.stdout.write(content);
    }
  } finally {
    db.close();
  }
}

function enrichTask(id?: string): void {
  if (!id) {
    console.error("usage: batonq enrich <external_id>");
    process.exit(2);
  }
  const db = openTaskDb();
  try {
    const row = db
      .query("SELECT * FROM tasks WHERE external_id = ?")
      .get(id) as any;
    if (!row) {
      console.error(`No task with external_id ${id}.`);
      process.exit(1);
    }
    if (row.status !== "draft") {
      console.error(
        `Task ${id} is ${row.status}, can only enrich drafts. Use TUI to add a draft first.`
      );
      process.exit(1);
    }
    const repoPath = resolveRepoPath(row.repo);
    // Spawned by tasks-core: `claude -p --model opus --dangerously-skip-permissions`
    console.log(`→ enrich (claude --model opus) [${row.repo}]: ${row.body.slice(0, 80)}…`);
    const result = enrichTaskBody(row.body, repoPath);
    const applied = applyEnrichment(db, TASKS_PATH, id, result);
    if (applied.kind === "questions") {
      console.log(`? questions stored on draft (status unchanged):`);
      console.log(applied.questions);
      console.log(``);
      console.log(`Answer the questions, edit the draft body in TASKS.md, then re-run: batonq enrich ${id}`);
    } else {
      console.log(`✓ enriched. Body + verify/judge updated. Status still draft.`);
      if (applied.newExternalId !== applied.oldExternalId) {
        console.log(`  external_id: ${applied.oldExternalId} → ${applied.newExternalId}`);
      }
      console.log(`  Promote when ready: batonq promote ${applied.newExternalId}`);
    }
  } finally {
    db.close();
  }
}

function promoteTask(id?: string): void {
  if (!id) {
    console.error("usage: batonq promote <external_id>");
    process.exit(2);
  }
  const db = openTaskDb();
  try {
    const ok = promoteDraftToPending(db, TASKS_PATH, id);
    if (!ok) {
      const row = db
        .query("SELECT status FROM tasks WHERE external_id = ?")
        .get(id) as any;
      if (!row) {
        console.error(`No task with external_id ${id}.`);
      } else {
        console.error(`Task ${id} is ${row.status}, only drafts can be promoted.`);
      }
      process.exit(1);
    }
    console.log(`✓ promoted: ${id} (draft → pending). batonq pick will see it now.`);
  } finally {
    db.close();
  }
}

// ── report ────────────────────────────────────────────────────────────────────

function report() {
  if (!existsSync(LOG_PATH)) {
    console.log("No events to report.");
    return;
  }
  const sinceIdx = process.argv.indexOf("--since");
  const untilIdx = process.argv.indexOf("--until");
  const jsonOut = process.argv.includes("--json");
  const since = sinceIdx > 0 ? Date.parse(process.argv[sinceIdx + 1]) : 0;
  const until = untilIdx > 0 ? Date.parse(process.argv[untilIdx + 1]) : Infinity;

  const events = readFileSync(LOG_PATH, "utf8")
    .trim()
    .split("\n")
    .map((l) => {
      try {
        return JSON.parse(l);
      } catch {
        return null;
      }
    })
    .filter((e): e is any => e !== null)
    .filter((e) => {
      const t = Date.parse(e.ts);
      return t >= since && t <= until;
    });

  if (events.length === 0) {
    console.log("No events in window.");
    return;
  }

  const sessions = new Set(events.map((e) => e.session));
  const repos = new Set(events.map((e) => e.git_root).filter(Boolean));
  const files = new Set(events.flatMap((e) => e.paths ?? []));
  const editKinds = new Set(["Edit", "Write", "MultiEdit"]);
  const editEvents = events.filter((e) => editKinds.has(e.tool));
  const readEvents = events.filter((e) => e.tool === "Read");
  const bashEvents = events.filter((e) => e.tool === "Bash");
  const preEdits = editEvents.filter((e) => e.phase === "pre");

  const collisions: any[] = [];
  for (let i = 0; i < preEdits.length; i++) {
    for (let j = i + 1; j < preEdits.length; j++) {
      const a = preEdits[i];
      const b = preEdits[j];
      if (a.session === b.session) continue;
      if (a.git_root !== b.git_root) continue;
      const overlap = (a.paths ?? []).some((p: string) => (b.paths ?? []).includes(p));
      if (!overlap) continue;
      const dt = Math.abs(Date.parse(a.ts) - Date.parse(b.ts)) / 1000;
      if (dt <= 300) collisions.push({ a, b, dt });
    }
  }

  const drifts: any[] = [];
  for (const r of readEvents) {
    const p = r.paths?.[0];
    if (!p) continue;
    const rHash = r.hashes?.[p];
    if (!rHash) continue;
    const t1 = Date.parse(r.ts);
    const write = preEdits
      .filter((w) => w.session === r.session && (w.paths ?? []).includes(p))
      .find((w) => {
        const t2 = Date.parse(w.ts);
        return t2 - t1 > 300_000 && w.hashes?.[p] && w.hashes[p] !== rHash;
      });
    if (write) drifts.push({ read: r, write });
  }

  const humanEdits: any[] = [];
  const byPath: Record<string, any[]> = {};
  for (const e of events) for (const p of e.paths ?? []) (byPath[p] ??= []).push(e);
  for (const [p, hist] of Object.entries(byPath)) {
    hist.sort((a, b) => Date.parse(a.ts) - Date.parse(b.ts));
    let lastPost: string | null = null;
    for (const ev of hist) {
      if (ev.phase === "pre" && editKinds.has(ev.tool)) {
        const h = ev.hashes?.[p];
        if (lastPost && h && h !== lastPost) humanEdits.push({ ev, path: p });
      }
      if (ev.phase === "post") {
        const h = ev.hashes?.[p];
        if (h) lastPost = h;
      }
    }
  }

  const destrOverShared: any[] = [];
  const postEvents = events.filter((e) => e.phase === "post");
  for (const b of bashEvents) {
    const t = Date.parse(b.ts);
    for (const p of b.paths ?? []) {
      const prior = postEvents.find((e) => {
        if (e.session === b.session) return false;
        if (!(e.paths ?? []).includes(p)) return false;
        const tp = Date.parse(e.ts);
        return tp < t && t - tp <= 300_000;
      });
      if (prior) {
        destrOverShared.push({ bash: b, write: prior, path: p });
        break;
      }
    }
  }

  const wouldWarn = collisions.length + drifts.length;
  const wouldBlock = collisions.length + destrOverShared.length;
  const sum =
    collisions.length + drifts.length + humanEdits.length + destrOverShared.length;
  const maxSingle = Math.max(
    collisions.length,
    drifts.length,
    humanEdits.length,
    destrOverShared.length
  );

  let suggest: string;
  if (sum < 10) suggest = "Ship §4C-v1 — low coordination pain.";
  else if (maxSingle > 40) suggest = "Ship §4A-v2 — real concurrency pain.";
  else suggest = "Middle zone — judgment call.";
  if (sum > 0 && humanEdits.length / sum > 0.6)
    suggest += " human_edits dominate — §4A-v2 hash-at-reacquire preferred.";
  if (sum > 0 && destrOverShared.length / sum > 0.4)
    suggest += " Bash-bypass is material.";

  const claudeVer = (() => {
    try {
      return execSync("claude --version", { stdio: ["ignore", "pipe", "ignore"] })
        .toString()
        .trim();
    } catch {
      return "unknown";
    }
  })();

  // Also pull DB-side stats (active claims, total released) for live ops
  let dbStats: any = null;
  if (existsSync(DB_PATH)) {
    const db = new Database(DB_PATH, { readonly: true });
    db.exec("PRAGMA busy_timeout=3000;");
    const activeClaims = (db.query("SELECT COUNT(*) AS n FROM claims WHERE released_at IS NULL").get() as any).n;
    const totalClaims = (db.query("SELECT COUNT(*) AS n FROM claims").get() as any).n;
    const totalSessions = (db.query("SELECT COUNT(*) AS n FROM sessions").get() as any).n;
    dbStats = { activeClaims, totalClaims, totalSessions };
    db.close();
  }

  if (jsonOut) {
    console.log(
      JSON.stringify(
        {
          window: { from: events[0].ts, to: events[events.length - 1].ts },
          claude_version: claudeVer,
          sessions: sessions.size,
          repos: Array.from(repos).map((r) => basename(r as string)),
          files: files.size,
          counters: {
            collisions: collisions.length,
            drifts: drifts.length,
            human_edits: humanEdits.length,
            destructive_bash_total: bashEvents.length,
            destructive_bash_over_shared: destrOverShared.length,
            would_warn: wouldWarn,
            would_block: wouldBlock,
            hook_errors: 0,
          },
          db_stats: dbStats,
          suggest,
        },
        null,
        2
      )
    );
    return;
  }

  console.log(`Measurement window: ${events[0].ts} → ${events[events.length - 1].ts}`);
  console.log(`Claude Code version (now): ${claudeVer}`);
  console.log(`Sessions observed: ${sessions.size}`);
  console.log(
    `Total events: ${editEvents.length} edit (pre+post), ${readEvents.length} read, ${bashEvents.length} destructive-bash`
  );
  console.log(`Unique files touched: ${files.size}`);
  console.log(
    `Unique repos: ${repos.size} (${Array.from(repos).map((r) => basename(r as string)).join(", ")})`
  );
  if (dbStats) {
    console.log(
      `Coord state: ${dbStats.activeClaims} active claim(s), ${dbStats.totalClaims} total, ${dbStats.totalSessions} session(s)`
    );
  }
  console.log();
  const row = (label: string, n: number, suf = "") =>
    console.log(`  ${label.padEnd(34)} ${String(n).padStart(4)}  ${suf}`);
  row("collisions:", collisions.length);
  row("drifts:", drifts.length);
  row("human_edits:", humanEdits.length);
  row("destructive_bash_total:", bashEvents.length);
  row("destructive_bash_over_shared:", destrOverShared.length);
  row("would_warn:", wouldWarn, "(cry-wolf sim)");
  row("would_block:", wouldBlock, "(false-deny sim)");
  row("hook_errors:", 0);
  console.log();
  console.log(`Decision (thresholds 10/40):`);
  console.log(`  sum = ${sum}, max single = ${maxSingle}`);
  console.log(`  → ${suggest}`);

  if (sum > 0) {
    console.log();
    console.log("Examples:");
    const rel = (p: string, root: string) => p.replace(root + "/", "");
    for (const c of collisions.slice(0, 3))
      console.log(
        `  collision: ${basename(c.a.git_root)}/${rel(c.a.paths[0], c.a.git_root)} (${c.a.session.slice(0, 6)}+${c.b.session.slice(0, 6)}, ${Math.round(c.dt)}s apart)`
      );
    for (const d of drifts.slice(0, 3)) {
      const dt = Math.round((Date.parse(d.write.ts) - Date.parse(d.read.ts)) / 1000);
      console.log(
        `  drift: ${basename(d.read.git_root)}/${rel(d.read.paths[0], d.read.git_root)} (read at T, write at T+${dt}s, hash changed)`
      );
    }
    for (const h of humanEdits.slice(0, 3))
      console.log(
        `  human_edit: ${basename(h.ev.git_root)}/${rel(h.path, h.ev.git_root)}`
      );
    for (const d of destrOverShared.slice(0, 3)) {
      const dt = Math.round((Date.parse(d.bash.ts) - Date.parse(d.write.ts)) / 1000);
      console.log(
        `  destructive_bash_over_shared: ${basename(d.bash.git_root)}/${rel(d.path, d.bash.git_root)} (${d.bash.bash_pattern}, ${dt}s after other write)`
      );
    }
  }
}
