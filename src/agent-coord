// agent-run: smoke-test entry point for the AgentRunner abstraction. Lets
// us invoke any tool head-to-head from the shell, e.g.
//   batonq agent-run --tool=codex --prompt="say hi" --cwd=/tmp
// Exits with the agent's exit code so callers can chain on success.
function runAgentRun(args: string[]): void {
  const flags = parseAgentFlags(args);
  if (!flags.tool || !flags.prompt) {
    console.error(
      "usage: batonq agent-run --tool=<claude|codex> --prompt=<text> [--cwd=<dir>] [--timeout-sec=N] [--system-prompt=<text>]",
    );
    process.exit(2);
  }
  if (!IMPLEMENTED_TOOLS.includes(flags.tool)) {
    console.error(
      `unknown tool: ${flags.tool} (implemented: ${IMPLEMENTED_TOOLS.join(", ")})`,
    );
    process.exit(2);
  }
  const runner = getRunner(flags.tool);
  if (!runner.available()) {
    console.error(`tool '${flags.tool}' is not on PATH`);
    process.exit(127);
  }
  const result = runner.run({
    prompt: flags.prompt,
    cwd: flags.cwd ?? process.cwd(),
    timeoutMs: flags.timeoutSec ? flags.timeoutSec * 1000 : undefined,
    systemPrompt: flags.systemPrompt,
  });
  process.stdout.write(result.stdout);
  if (result.stderr) process.stderr.write(result.stderr);
  console.error(
    `\n[agent-run] ${result.tool} exited ${result.exitCode} after ${result.durationMs}ms${result.timedOut ? " (timeout)" : ""}`,
  );
  process.exit(result.exitCode);
}

// Tiny --key=value parser scoped to agent-run flags. Keeping it local so we
// don't pull a CLI-arg lib into the binary.
function parseAgentFlags(args: string[]): {
  tool?: AgentTool;
  prompt?: string;
  cwd?: string;
  timeoutSec?: number;
  systemPrompt?: string;
} {
  const out: ReturnType<typeof parseAgentFlags> = {};
  for (const a of args) {
    const m = a.match(/^--([a-z-]+)=(.*)$/);
    if (!m) continue;
    const [, k, v] = m;
    if (k === "tool") out.tool = v as AgentTool;
    else if (k === "prompt") out.prompt = v;
    else if (k === "cwd") out.cwd = v;
    else if (k === "timeout-sec") out.timeoutSec = Number(v);
    else if (k === "system-prompt") out.systemPrompt = v;
  }
  return out;
}

function runLoopStatus(args: string[]): void {
  const { eventsAgeSec, findLoopCurrentTask, probeClaudeInfo, probeLoopPid } =
    require("./loop-status");
  const loopPid = probeLoopPid();
  const claude = probeClaudeInfo();
  const state =
    loopPid === null ? "dead" : claude === null ? "idle" : "running";
  const db = openTaskDb();
  let currentTask: any = null;
  try {
    currentTask = findLoopCurrentTask(db, loopPid);
  } finally {
    db.close();
  }
  const payload = {
    state,
    loopPid,
    currentTask,
    claude,
    eventsAgeSec: eventsAgeSec(LOG_PATH),
  };
  if (args.includes("--json")) {
    console.log(JSON.stringify(payload));
    return;
  }
  const age = payload.eventsAgeSec;
  console.log(
    `loop: ${state}${loopPid !== null ? ` (pid ${loopPid})` : ""}` +
      `  claude: ${claude ? `pid ${claude.pid} up ${claude.uptimeSec}s` : "— (none)"}` +
      `  events: ${age === null ? "—" : `${age}s ago`}` +
      `  task: ${currentTask ? `${currentTask.externalId.slice(0, 8)} · ${currentTask.body.slice(0, 50)}` : "—"}`
  );
}

