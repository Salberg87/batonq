// ── report ────────────────────────────────────────────────────────────────────

function report() {
  if (!existsSync(LOG_PATH)) {
    console.log("No events to report.");
    return;
  }
  const sinceIdx = process.argv.indexOf("--since");
  const untilIdx = process.argv.indexOf("--until");
  const jsonOut = process.argv.includes("--json");
  const since = sinceIdx > 0 ? Date.parse(process.argv[sinceIdx + 1]) : 0;
  const until = untilIdx > 0 ? Date.parse(process.argv[untilIdx + 1]) : Infinity;

  const events = readFileSync(LOG_PATH, "utf8")
    .trim()
    .split("\n")
    .map((l) => {
      try {
        return JSON.parse(l);
      } catch {
        return null;
      }
    })
    .filter((e): e is any => e !== null)
    .filter((e) => {
      const t = Date.parse(e.ts);
      return t >= since && t <= until;
    });

  if (events.length === 0) {
    console.log("No events in window.");
    return;
  }

  const sessions = new Set(events.map((e) => e.session));
  const repos = new Set(events.map((e) => e.git_root).filter(Boolean));
  const files = new Set(events.flatMap((e) => e.paths ?? []));
  const editKinds = new Set(["Edit", "Write", "MultiEdit"]);
  const editEvents = events.filter((e) => editKinds.has(e.tool));
  const readEvents = events.filter((e) => e.tool === "Read");
  const bashEvents = events.filter((e) => e.tool === "Bash");
  const preEdits = editEvents.filter((e) => e.phase === "pre");

  const collisions: any[] = [];
  for (let i = 0; i < preEdits.length; i++) {
    for (let j = i + 1; j < preEdits.length; j++) {
      const a = preEdits[i];
      const b = preEdits[j];
      if (a.session === b.session) continue;
      if (a.git_root !== b.git_root) continue;
      const overlap = (a.paths ?? []).some((p: string) => (b.paths ?? []).includes(p));
      if (!overlap) continue;
      const dt = Math.abs(Date.parse(a.ts) - Date.parse(b.ts)) / 1000;
      if (dt <= 300) collisions.push({ a, b, dt });
    }
  }

  const drifts: any[] = [];
  for (const r of readEvents) {
    const p = r.paths?.[0];
    if (!p) continue;
    const rHash = r.hashes?.[p];
    if (!rHash) continue;
    const t1 = Date.parse(r.ts);
    const write = preEdits
      .filter((w) => w.session === r.session && (w.paths ?? []).includes(p))
      .find((w) => {
        const t2 = Date.parse(w.ts);
        return t2 - t1 > 300_000 && w.hashes?.[p] && w.hashes[p] !== rHash;
      });
    if (write) drifts.push({ read: r, write });
  }

  const humanEdits: any[] = [];
  const byPath: Record<string, any[]> = {};
  for (const e of events) for (const p of e.paths ?? []) (byPath[p] ??= []).push(e);
  for (const [p, hist] of Object.entries(byPath)) {
    hist.sort((a, b) => Date.parse(a.ts) - Date.parse(b.ts));
    let lastPost: string | null = null;
    for (const ev of hist) {
      if (ev.phase === "pre" && editKinds.has(ev.tool)) {
        const h = ev.hashes?.[p];
        if (lastPost && h && h !== lastPost) humanEdits.push({ ev, path: p });
      }
      if (ev.phase === "post") {
        const h = ev.hashes?.[p];
        if (h) lastPost = h;
      }
    }
  }

  const destrOverShared: any[] = [];
  const postEvents = events.filter((e) => e.phase === "post");
  for (const b of bashEvents) {
    const t = Date.parse(b.ts);
    for (const p of b.paths ?? []) {
      const prior = postEvents.find((e) => {
        if (e.session === b.session) return false;
        if (!(e.paths ?? []).includes(p)) return false;
        const tp = Date.parse(e.ts);
        return tp < t && t - tp <= 300_000;
      });
      if (prior) {
        destrOverShared.push({ bash: b, write: prior, path: p });
        break;
      }
    }
  }

  const wouldWarn = collisions.length + drifts.length;
  const wouldBlock = collisions.length + destrOverShared.length;
  const sum =
    collisions.length + drifts.length + humanEdits.length + destrOverShared.length;
  const maxSingle = Math.max(
    collisions.length,
    drifts.length,
    humanEdits.length,
    destrOverShared.length
  );

  let suggest: string;
  if (sum < 10) suggest = "Ship §4C-v1 — low coordination pain.";
  else if (maxSingle > 40) suggest = "Ship §4A-v2 — real concurrency pain.";
  else suggest = "Middle zone — judgment call.";
  if (sum > 0 && humanEdits.length / sum > 0.6)
    suggest += " human_edits dominate — §4A-v2 hash-at-reacquire preferred.";
  if (sum > 0 && destrOverShared.length / sum > 0.4)
    suggest += " Bash-bypass is material.";

  const claudeVer = (() => {
    try {
      return execSync("claude --version", { stdio: ["ignore", "pipe", "ignore"] })
        .toString()
        .trim();
    } catch {
      return "unknown";
    }
  })();

  // Also pull DB-side stats (active claims, total released) for live ops
  let dbStats: any = null;
  if (existsSync(DB_PATH)) {
    const db = new Database(DB_PATH, { readonly: true });
    db.exec("PRAGMA busy_timeout=3000;");
    const activeClaims = (db.query("SELECT COUNT(*) AS n FROM claims WHERE released_at IS NULL").get() as any).n;
    const totalClaims = (db.query("SELECT COUNT(*) AS n FROM claims").get() as any).n;
    const totalSessions = (db.query("SELECT COUNT(*) AS n FROM sessions").get() as any).n;
    dbStats = { activeClaims, totalClaims, totalSessions };
    db.close();
  }

  if (jsonOut) {
    console.log(
      JSON.stringify(
        {
          window: { from: events[0].ts, to: events[events.length - 1].ts },
          claude_version: claudeVer,
          sessions: sessions.size,
          repos: Array.from(repos).map((r) => basename(r as string)),
          files: files.size,
          counters: {
            collisions: collisions.length,
            drifts: drifts.length,
            human_edits: humanEdits.length,
            destructive_bash_total: bashEvents.length,
            destructive_bash_over_shared: destrOverShared.length,
            would_warn: wouldWarn,
            would_block: wouldBlock,
            hook_errors: 0,
          },
          db_stats: dbStats,
          suggest,
        },
        null,
        2
      )
    );
    return;
  }

  console.log(`Measurement window: ${events[0].ts} → ${events[events.length - 1].ts}`);
  console.log(`Claude Code version (now): ${claudeVer}`);
  console.log(`Sessions observed: ${sessions.size}`);
  console.log(
    `Total events: ${editEvents.length} edit (pre+post), ${readEvents.length} read, ${bashEvents.length} destructive-bash`
  );
  console.log(`Unique files touched: ${files.size}`);
  console.log(
    `Unique repos: ${repos.size} (${Array.from(repos).map((r) => basename(r as string)).join(", ")})`
  );
  if (dbStats) {
    console.log(
      `Coord state: ${dbStats.activeClaims} active claim(s), ${dbStats.totalClaims} total, ${dbStats.totalSessions} session(s)`
    );
  }
  console.log();
  const row = (label: string, n: number, suf = "") =>
    console.log(`  ${label.padEnd(34)} ${String(n).padStart(4)}  ${suf}`);
  row("collisions:", collisions.length);
  row("drifts:", drifts.length);
  row("human_edits:", humanEdits.length);
  row("destructive_bash_total:", bashEvents.length);
  row("destructive_bash_over_shared:", destrOverShared.length);
  row("would_warn:", wouldWarn, "(cry-wolf sim)");
  row("would_block:", wouldBlock, "(false-deny sim)");
  row("hook_errors:", 0);
  console.log();
  console.log(`Decision (thresholds 10/40):`);
  console.log(`  sum = ${sum}, max single = ${maxSingle}`);
  console.log(`  → ${suggest}`);

  if (sum > 0) {
    console.log();
    console.log("Examples:");
    const rel = (p: string, root: string) => p.replace(root + "/", "");
    for (const c of collisions.slice(0, 3))
      console.log(
        `  collision: ${basename(c.a.git_root)}/${rel(c.a.paths[0], c.a.git_root)} (${c.a.session.slice(0, 6)}+${c.b.session.slice(0, 6)}, ${Math.round(c.dt)}s apart)`
      );
    for (const d of drifts.slice(0, 3)) {
      const dt = Math.round((Date.parse(d.write.ts) - Date.parse(d.read.ts)) / 1000);
      console.log(
        `  drift: ${basename(d.read.git_root)}/${rel(d.read.paths[0], d.read.git_root)} (read at T, write at T+${dt}s, hash changed)`
      );
    }
    for (const h of humanEdits.slice(0, 3))
      console.log(
        `  human_edit: ${basename(h.ev.git_root)}/${rel(h.path, h.ev.git_root)}`
      );
    for (const d of destrOverShared.slice(0, 3)) {
      const dt = Math.round((Date.parse(d.bash.ts) - Date.parse(d.write.ts)) / 1000);
      console.log(
        `  destructive_bash_over_shared: ${basename(d.bash.git_root)}/${rel(d.path, d.bash.git_root)} (${d.bash.bash_pattern}, ${dt}s after other write)`
      );
    }
  }
}
