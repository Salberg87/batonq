#!/usr/bin/env bun
// agent-coord — CLI for measurement + coordination.
// Commands: check | tail | report | status | release | sweep

import { Database } from "bun:sqlite";
import { existsSync, readFileSync, writeFileSync, statSync, mkdirSync, unlinkSync } from "node:fs";
import { execSync, spawnSync } from "node:child_process";
import { basename, isAbsolute, resolve } from "node:path";
import { homedir } from "node:os";
import { createHash } from "node:crypto";
import {
  parseTasksFile as parseTasksFileCore,
  externalId,
  initClaimsSchema,
  initTaskSchema,
  syncTasks as syncTasksCore,
  selectCandidate,
  claimCandidate,
  runVerify,
  runJudge as runJudgeCore,
  getGitDiffSinceClaim as getGitDiffSinceClaimCore,
  rewriteMdTaskStatus as rewriteMdTaskStatusCore,
  enrichTaskBody,
  applyEnrichment,
  promoteDraftToPending,
  sweepTasks as sweepTasksCore,
  type ParsedTask,
} from "./tasks-core";
import { migrate } from "./migrate";

const HOME = homedir();
const LOG_DIR = `${HOME}/.claude/batonq-measurement`;
const LOG_PATH = `${LOG_DIR}/events.jsonl`;
const DB_PATH = `${HOME}/.claude/batonq-state.db`;
const HOOK_PATH = `${HOME}/bin/batonq-hook`;
const SETTINGS_PATH = `${HOME}/.claude/settings.json`;
const TASKS_PATH = `${HOME}/DEV/TASKS.md`;

// One-shot rename migration from legacy `.claude/agent-coord-*` layout.
// No-op on fresh installs and after the first successful migration.
// Runs before any command dispatch so every entry point sees the new paths.
try {
  migrate();
} catch {
  // migration is best-effort; never block the CLI
}

const cmd = process.argv[2];

switch (cmd) {
  case "--version":
  case "-v":
  case "version":
    printVersion();
    break;
  case "check":
    check();
    break;
  case "doctor":
    doctor();
    break;
  case "tail":
    tail();
    break;
  case "report":
    report();
    break;
  case "status":
    status();
    break;
  case "release":
    release(process.argv[3]);
    break;
  case "sweep":
    sweepCmd();
    break;
  case "sweep-tasks":
    sweepTasksCmd();
    break;
  case "sync-tasks":
    syncTasks(true);
    break;
  case "pick":
    pickTask();
    break;
  case "mine":
    mineTask();
    break;
  case "done":
    doneTask(process.argv[3]);
    break;
  case "abandon":
    abandonTask(process.argv[3]);
    break;
  case "tasks":
    listTasks();
    break;
  case "enrich":
    enrichTask(process.argv[3]);
    break;
  case "promote":
    promoteTask(process.argv[3]);
    break;
  case "tui":
    runTui();
    break;
  case "loop-status":
    runLoopStatus(process.argv.slice(3));
    break;
  case "uninstall":
    runUninstall();
    break;
  default:
    console.error(
      "usage: batonq\n" +
        "  Coordination:  check | doctor | status | release <path> | sweep | sweep-tasks\n" +
        "  Measurement:   tail [-n N] | report [--since ISO] [--until ISO] [--json]\n" +
        "  Tasks:         sync-tasks | pick | mine | done [<id>] | abandon [<id>] | tasks\n" +
        "  Drafts:        enrich <id> | promote <id>\n" +
        "  Dashboard:     tui | loop-status [--json]\n" +
        "  Exit:          uninstall [--remove-state|--keep-state]"
    );
    process.exit(2);
}

function runLoopStatus(args: string[]): void {
  const { eventsAgeSec, findLoopCurrentTask, probeClaudeInfo, probeLoopPid } =
    require("./loop-status");
  const loopPid = probeLoopPid();
  const claude = probeClaudeInfo();
  const state =
    loopPid === null ? "dead" : claude === null ? "idle" : "running";
  const db = openTaskDb();
  let currentTask: any = null;
  try {
    currentTask = findLoopCurrentTask(db, loopPid);
  } finally {
    db.close();
  }
  const payload = {
    state,
    loopPid,
    currentTask,
    claude,
    eventsAgeSec: eventsAgeSec(LOG_PATH),
  };
  if (args.includes("--json")) {
    console.log(JSON.stringify(payload));
    return;
  }
  const age = payload.eventsAgeSec;
  console.log(
    `loop: ${state}${loopPid !== null ? ` (pid ${loopPid})` : ""}` +
      `  claude: ${claude ? `pid ${claude.pid} up ${claude.uptimeSec}s` : "— (none)"}` +
      `  events: ${age === null ? "—" : `${age}s ago`}` +
      `  task: ${currentTask ? `${currentTask.externalId.slice(0, 8)} · ${currentTask.body.slice(0, 50)}` : "—"}`
  );
}

function runTui(): void {
  const here = new URL("./tui.tsx", import.meta.url).pathname;
  const r = spawnSync("bun", ["run", here], { stdio: "inherit" });
  process.exit(r.status ?? 0);
}

// `uninstall` delegates to uninstall.sh so install and uninstall share one
// source of truth for bindir layout and the settings.json hook filter.
// Resolution order:
//   1. $BATONQ_UNINSTALL_SCRIPT (tests, vendored installs)
//   2. ../uninstall.sh relative to this module (dev checkout)
//   3. curl-pipe the script from GitHub (installed binary — no local repo)
function runUninstall(): void {
  const extraArgs = process.argv.slice(3);
  const override = process.env.BATONQ_UNINSTALL_SCRIPT;
  if (override && existsSync(override)) {
    const r = spawnSync("sh", [override, ...extraArgs], { stdio: "inherit" });
    process.exit(r.status ?? 0);
  }
  const local = new URL("../uninstall.sh", import.meta.url).pathname;
  if (existsSync(local)) {
    const r = spawnSync("sh", [local, ...extraArgs], { stdio: "inherit" });
    process.exit(r.status ?? 0);
  }
  console.log("Running remote uninstaller from GitHub…");
  const args = extraArgs.length > 0 ? ` ${extraArgs.map((a) => `'${a.replace(/'/g, "'\\''")}'`).join(" ")}` : "";
  const r = spawnSync(
    "sh",
    [
      "-c",
      `curl -fsSL https://raw.githubusercontent.com/Salberg87/batonq/main/uninstall.sh | sh -s --${args}`,
    ],
    { stdio: "inherit" }
  );
  process.exit(r.status ?? 0);
}

// ── version ───────────────────────────────────────────────────────────────────

function printVersion(): void {
  const pkgPath = new URL("../package.json", import.meta.url).pathname;
  let version = "unknown";
  try {
    version = JSON.parse(readFileSync(pkgPath, "utf8")).version ?? "unknown";
  } catch {
    // keep "unknown"
  }
  let commit = "unknown";
  try {
    commit = execSync("git rev-parse --short HEAD", {
      cwd: new URL("..", import.meta.url).pathname,
      stdio: ["ignore", "pipe", "ignore"],
    })
      .toString()
      .trim() || "unknown";
  } catch {
    // not a git checkout (e.g. tarball install) → keep "unknown"
  }
  console.log(`batonq v${version} (commit ${commit})`);
  process.exit(0);
}

// ── check ─────────────────────────────────────────────────────────────────────

function check() {
  let green = true;
  const ok = (m: string) => console.log("  ok   " + m);
  const bad = (m: string) => {
    console.error("  FAIL " + m);
    green = false;
  };
  const warn = (m: string) => console.log("  warn " + m);

  if (existsSync(HOOK_PATH)) {
    const mode = statSync(HOOK_PATH).mode & 0o111;
    if (mode) ok(`hook binary executable: ${HOOK_PATH}`);
    else bad(`hook binary not executable: ${HOOK_PATH}`);
  } else bad(`hook binary missing: ${HOOK_PATH}`);

  if (existsSync(SETTINGS_PATH)) {
    try {
      const cfg = JSON.parse(readFileSync(SETTINGS_PATH, "utf8"));
      const pre = cfg.hooks?.PreToolUse ?? [];
      const post = cfg.hooks?.PostToolUse ?? [];
      const has = (arr: any[], pat: RegExp) =>
        arr.some((b: any) =>
          b.hooks?.some((h: any) => typeof h.command === "string" && pat.test(h.command))
        );
      if (has(pre, /(?:agent-coord-hook|batonq-hook)\s+pre\b/)) ok("PreToolUse hook (pre) configured");
      else bad("PreToolUse hook (pre) NOT configured");
      if (has(pre, /(?:agent-coord-hook|batonq-hook)\s+bash\b/)) ok("PreToolUse hook (bash) configured");
      else bad("PreToolUse hook (bash) NOT configured");
      if (has(post, /(?:agent-coord-hook|batonq-hook)\s+post\b/)) ok("PostToolUse hook (post) configured");
      else bad("PostToolUse hook (post) NOT configured");
    } catch (e: any) {
      bad(`could not parse settings.json: ${e.message}`);
    }
  } else bad(`settings.json missing: ${SETTINGS_PATH}`);

  if (!existsSync(LOG_DIR)) {
    try {
      mkdirSync(LOG_DIR, { recursive: true, mode: 0o700 });
      ok(`created log dir: ${LOG_DIR}`);
    } catch (e: any) {
      bad(`could not create log dir: ${e.message}`);
    }
  } else ok(`log dir exists: ${LOG_DIR}`);

  for (const [name, c] of [
    ["bun", "bun --version"],
    ["git", "git --version"],
  ] as const) {
    try {
      const v = execSync(c, { stdio: ["ignore", "pipe", "ignore"] }).toString().trim();
      ok(`${name}: ${v}`);
    } catch {
      bad(`${name} not on PATH`);
    }
  }
  try {
    const v = execSync("claude --version", { stdio: ["ignore", "pipe", "ignore"] })
      .toString()
      .trim();
    ok(`claude: ${v}`);
  } catch {
    warn("claude CLI version could not be detected (non-fatal)");
  }

  if (existsSync(LOG_PATH)) {
    ok(`events log: ${LOG_PATH} (${Math.round(statSync(LOG_PATH).size / 1024)} KB)`);
  } else warn(`events log not created yet — will appear on first in-scope tool call`);

  if (existsSync(DB_PATH)) {
    ok(`state.db: ${DB_PATH} (${Math.round(statSync(DB_PATH).size / 1024)} KB)`);
  } else warn(`state.db not created yet — will appear on first in-scope tool call`);

  process.exit(green ? 0 : 1);
}

// ── doctor ────────────────────────────────────────────────────────────────────
//
// `check` is the legacy single-pass health probe. `doctor` is the structured
// alternative: 5 categories (Binaries, Installation, State, Scope, Live), every
// row carries pass/warn/fail + an actionable `fix:` hint, and the closing
// summary lists every critical and warning so the output is copy-pastable into
// an issue. Diagnostic-only — never mutates state.

type DoctorStatus = "pass" | "warn" | "fail";
type DoctorCheck = { label: string; status: DoctorStatus; fix?: string };
type DoctorCategory = { name: string; checks: DoctorCheck[] };

function doctorSym(s: DoctorStatus): string {
  return s === "pass" ? "✓" : s === "warn" ? "⚠" : "✗";
}

function doctor(): void {
  const cats: DoctorCategory[] = [
    { name: "Binaries", checks: [] },
    { name: "Installation", checks: [] },
    { name: "State", checks: [] },
    { name: "Scope", checks: [] },
    { name: "Live", checks: [] },
  ];
  const add = (cat: string, label: string, status: DoctorStatus, fix?: string) => {
    const c = cats.find((x) => x.name === cat);
    if (!c) return;
    c.checks.push({ label, status, fix });
  };

  // ── 1. Binaries ─────────────────────────────────────────────────────────────
  // bun ≥ 1.0, git ≥ 2.0, jq ≥ 1.0 are hard requirements. claude is warn-only
  // because the queue itself works without it; only `enrich` and `batonq-loop`
  // need a Claude Code install.
  const binCheck = (name: string, cmd: string, minMajor: number, fix: string) => {
    try {
      const v = execSync(cmd, { stdio: ["ignore", "pipe", "ignore"] }).toString().trim();
      const m = v.match(/(\d+)\.(\d+)(?:\.(\d+))?/);
      if (m && parseInt(m[1] ?? "0", 10) >= minMajor) {
        add("Binaries", `${name}: ${v}`, "pass");
      } else {
        add("Binaries", `${name}: ${v} (need ≥ ${minMajor}.0)`, "fail", fix);
      }
    } catch {
      add("Binaries", `${name}: not found on PATH`, "fail", fix);
    }
  };
  binCheck("bun", "bun --version", 1, "curl -fsSL https://bun.sh/install | bash");
  binCheck("git", "git --version", 2, "install git via your package manager (brew install git / apt-get install git)");
  try {
    const v = execSync("claude --version", { stdio: ["ignore", "pipe", "ignore"] })
      .toString()
      .trim();
    add("Binaries", `claude: ${v}`, "pass");
  } catch {
    add(
      "Binaries",
      "claude: not found on PATH (optional — needed only for batonq-loop and `enrich`)",
      "warn",
      "install Claude Code: https://docs.claude.com/claude-code"
    );
  }
  binCheck("jq", "jq --version", 1, "brew install jq  (or: sudo apt-get install -y jq)");

  // ── 2. Installation ─────────────────────────────────────────────────────────
  // batonq must be on PATH and executable; the three install.sh-wired hook
  // matchers must be present in settings.json (PreToolUse pre, PreToolUse bash,
  // PostToolUse post); each hook command path must point at an executable.
  let batonqPath: string | null = null;
  try {
    batonqPath = execSync("command -v batonq", { stdio: ["ignore", "pipe", "ignore"] })
      .toString()
      .trim();
  } catch {
    batonqPath = null;
  }
  if (batonqPath) {
    add("Installation", `batonq on PATH: ${batonqPath}`, "pass");
    try {
      const mode = statSync(batonqPath).mode & 0o111;
      if (mode) add("Installation", `batonq has execute bit set`, "pass");
      else add("Installation", `batonq missing execute bit`, "fail", `chmod +x ${batonqPath}`);
    } catch (e: any) {
      add("Installation", `batonq stat failed: ${e.message}`, "fail");
    }
  } else {
    add(
      "Installation",
      `batonq not on PATH`,
      "fail",
      `add ~/.local/bin (or ~/bin) to PATH and re-run install.sh`
    );
  }

  if (!existsSync(SETTINGS_PATH)) {
    add(
      "Installation",
      `settings.json missing: ${SETTINGS_PATH}`,
      "fail",
      `re-run installer: curl -fsSL https://raw.githubusercontent.com/Salberg87/batonq/main/install.sh | sh`
    );
  } else {
    let cfg: any = null;
    try {
      cfg = JSON.parse(readFileSync(SETTINGS_PATH, "utf8"));
    } catch (e: any) {
      add(
        "Installation",
        `settings.json parse error: ${e.message}`,
        "fail",
        `fix the JSON at ${SETTINGS_PATH} (jq . ${SETTINGS_PATH} to locate)`
      );
    }
    if (cfg) {
      const hookRe = /(?:agent-coord-hook|batonq-hook)/;
      const hookPreRe = /(?:agent-coord-hook|batonq-hook)\s+pre\b/;
      const hookBashRe = /(?:agent-coord-hook|batonq-hook)\s+bash\b/;
      const hookPostRe = /(?:agent-coord-hook|batonq-hook)\s+post\b/;
      const has = (event: string, pat: RegExp) => {
        const arr = cfg.hooks?.[event] ?? [];
        return arr.some((b: any) =>
          (b.hooks ?? []).some((h: any) => typeof h.command === "string" && pat.test(h.command))
        );
      };
      if (has("PreToolUse", hookPreRe))
        add("Installation", `PreToolUse hook (pre, Read|Edit|Write|MultiEdit)`, "pass");
      else
        add(
          "Installation",
          `PreToolUse hook (pre) NOT configured`,
          "fail",
          `re-run install.sh — it merges hooks idempotently`
        );
      if (has("PreToolUse", hookBashRe))
        add("Installation", `PreToolUse hook (bash, Bash)`, "pass");
      else
        add(
          "Installation",
          `PreToolUse hook (bash) NOT configured`,
          "fail",
          `re-run install.sh`
        );
      if (has("PostToolUse", hookPostRe))
        add("Installation", `PostToolUse hook (post, Edit|Write|MultiEdit)`, "pass");
      else
        add(
          "Installation",
          `PostToolUse hook (post) NOT configured`,
          "fail",
          `re-run install.sh`
        );

      const hookPaths = new Set<string>();
      for (const evt of ["PreToolUse", "PostToolUse"]) {
        for (const block of cfg.hooks?.[evt] ?? []) {
          for (const h of block.hooks ?? []) {
            if (typeof h.command === "string" && hookRe.test(h.command)) {
              const m = h.command.trim().match(/^(\S+)/);
              if (m) hookPaths.add(m[1]);
            }
          }
        }
      }
      for (const hp of hookPaths) {
        const expanded = hp.replace(/^~/, HOME);
        if (!existsSync(expanded)) {
          add(
            "Installation",
            `hook binary missing: ${expanded}`,
            "fail",
            `re-run install.sh to (re)install batonq-hook`
          );
        } else {
          const mode = statSync(expanded).mode & 0o111;
          if (mode)
            add("Installation", `hook binary executable: ${expanded}`, "pass");
          else
            add(
              "Installation",
              `hook binary not executable: ${expanded}`,
              "fail",
              `chmod +x ${expanded}`
            );
        }
      }
    }
  }

  // ── 3. State ────────────────────────────────────────────────────────────────
  // state.db existence is informational (lazy-created by the hook), but if it
  // exists it must pass integrity_check and contain the three core tables.
  // TASKS.md must parse cleanly. events.jsonl directory must be writable.
  if (!existsSync(DB_PATH)) {
    add(
      "State",
      `state.db not created yet: ${DB_PATH}`,
      "warn",
      `make any tool call inside a repo under ~/DEV — the hook creates the db lazily`
    );
  } else {
    add(
      "State",
      `state.db exists: ${DB_PATH} (${Math.round(statSync(DB_PATH).size / 1024)} KB)`,
      "pass"
    );
    let db: Database | null = null;
    try {
      db = new Database(DB_PATH, { readonly: true });
      db.exec("PRAGMA busy_timeout=3000;");
      const integrity: any = db.query("PRAGMA integrity_check").get();
      const integrityOk = integrity?.integrity_check === "ok";
      if (integrityOk) add("State", `PRAGMA integrity_check: ok`, "pass");
      else
        add(
          "State",
          `PRAGMA integrity_check: ${JSON.stringify(integrity)}`,
          "fail",
          `back up ${DB_PATH} then delete it — the hook recreates it cleanly`
        );
      const tables = new Set(
        (db.query("SELECT name FROM sqlite_master WHERE type='table'").all() as any[]).map(
          (r) => r.name
        )
      );
      for (const t of ["sessions", "claims", "tasks"]) {
        if (tables.has(t)) add("State", `table '${t}' present`, "pass");
        else
          add(
            "State",
            `table '${t}' missing`,
            "fail",
            `delete ${DB_PATH} so the schema initialiser recreates it on next hook run`
          );
      }
    } catch (e: any) {
      add(
        "State",
        `could not open state.db: ${e.message}`,
        "fail",
        `check file permissions on ${DB_PATH}; back up and delete to recreate`
      );
    } finally {
      db?.close();
    }
  }

  if (!existsSync(TASKS_PATH)) {
    add(
      "State",
      `TASKS.md missing: ${TASKS_PATH}`,
      "fail",
      `mkdir -p ~/DEV && printf '## Pending\\n\\n' > ${TASKS_PATH}`
    );
  } else {
    try {
      const { tasks } = parseTasksFile();
      add("State", `TASKS.md parses cleanly (${tasks.length} task(s))`, "pass");
    } catch (e: any) {
      add(
        "State",
        `TASKS.md parse error: ${e.message}`,
        "fail",
        `inspect ${TASKS_PATH} for malformed task lines`
      );
    }
  }

  if (!existsSync(LOG_DIR)) {
    add(
      "State",
      `events log dir missing: ${LOG_DIR}`,
      "warn",
      `mkdir -p ${LOG_DIR}`
    );
  } else {
    // probe writability with an empty append; clean the probe up so we don't
    // leave litter beside the real log.
    const probe = `${LOG_DIR}/.batonq-doctor-probe`;
    try {
      writeFileSync(probe, "", { flag: "a" });
      try { unlinkSync(probe); } catch {}
      if (existsSync(LOG_PATH)) {
        add(
          "State",
          `events.jsonl append-able (${Math.round(statSync(LOG_PATH).size / 1024)} KB)`,
          "pass"
        );
      } else {
        add(
          "State",
          `events.jsonl not yet created (will appear on first hook run); dir is writable`,
          "pass"
        );
      }
    } catch (e: any) {
      add(
        "State",
        `events log dir not writable: ${e.message}`,
        "fail",
        `chmod u+w ${LOG_DIR}`
      );
    }
  }

  // ── 4. Scope ────────────────────────────────────────────────────────────────
  // The hook only fires inside a git repo whose toplevel sits under ~/DEV/ or
  // ~/dev/. Outside that the queue still works for `any:*` tasks but
  // repo-scoped tasks won't pick.
  let gitRoot: string | null = null;
  try {
    gitRoot = execSync("git rev-parse --show-toplevel", {
      stdio: ["ignore", "pipe", "ignore"],
    })
      .toString()
      .trim();
    if (!gitRoot) gitRoot = null;
  } catch {
    gitRoot = null;
  }
  if (!gitRoot) {
    add(
      "Scope",
      `cwd is not inside a git repo (${process.cwd()})`,
      "warn",
      `cd into a git repo under ~/DEV/ or ~/dev/ before running batonq-loop`
    );
  } else {
    const inDev =
      gitRoot.startsWith(`${HOME}/DEV/`) ||
      gitRoot === `${HOME}/DEV` ||
      gitRoot.startsWith(`${HOME}/dev/`) ||
      gitRoot === `${HOME}/dev`;
    if (inDev) add("Scope", `git-root inside ~/DEV: ${gitRoot}`, "pass");
    else
      add(
        "Scope",
        `git-root outside ~/DEV/ and ~/dev/: ${gitRoot}`,
        "warn",
        `move/clone the repo under ~/DEV/ or ~/dev/ to be picked up by repo-scoped tasks`
      );

    // Repo fingerprint: sha256(remote.origin.url + "|" + first-commit-SHA),
    // matching the hook's R10 invariant. No network call — pure git plumbing.
    try {
      const out = execSync(
        `git config --get remote.origin.url 2>/dev/null; echo "---"; git rev-list --max-parents=0 HEAD 2>/dev/null | head -1`,
        { cwd: gitRoot, stdio: ["ignore", "pipe", "ignore"], timeout: 1500, shell: "/bin/sh" }
      ).toString();
      const [remote, firstCommit] = out.split("---\n").map((s) => s.trim());
      if (remote && firstCommit) {
        const fp = createHash("sha256")
          .update(`${remote}|${firstCommit}`)
          .digest("hex")
          .slice(0, 16);
        add("Scope", `repo-fingerprint: ${fp}`, "pass");
      } else {
        add(
          "Scope",
          `repo-fingerprint: falls back to path (no remote or no commits)`,
          "warn",
          `git remote add origin <url> — fingerprint becomes stable across clones`
        );
      }
    } catch (e: any) {
      add("Scope", `repo-fingerprint compute failed: ${e.message}`, "warn");
    }
  }

  // ── 5. Live ─────────────────────────────────────────────────────────────────
  // Snapshot of running activity. Stale sessions (>10 min) and stuck claims
  // (>10 min) are warnings, not failures — they're recoverable.
  const STUCK_MS = 10 * 60_000;
  if (!existsSync(DB_PATH)) {
    add("Live", `no state.db yet — no live activity`, "pass");
  } else {
    let db: Database | null = null;
    try {
      db = new Database(DB_PATH, { readonly: true });
      db.exec("PRAGMA busy_timeout=3000;");
      const sessions = db
        .query("SELECT * FROM sessions ORDER BY last_seen DESC")
        .all() as any[];
      if (sessions.length === 0) {
        add("Live", `no active sessions`, "pass");
      } else {
        for (const s of sessions) {
          const ageS = Math.round((Date.now() - Date.parse(s.last_seen)) / 1000);
          if (ageS > 600) {
            add(
              "Live",
              `session ${s.session_id.slice(0, 12)} stale (last_seen ${ageS}s ago)`,
              "warn",
              `batonq sweep — purges sessions and claims past their TTL`
            );
          } else {
            add(
              "Live",
              `session ${s.session_id.slice(0, 12)} alive (last_seen ${ageS}s ago, cwd=${s.cwd ?? "?"})`,
              "pass"
            );
          }
        }
      }
      // Claims (file-locks) stuck > 10 min.
      const stuckClaims = db
        .query(
          `SELECT file_path, session_id, acquired_at FROM claims
           WHERE released_at IS NULL AND acquired_at < ?`
        )
        .all(new Date(Date.now() - STUCK_MS).toISOString()) as any[];
      if (stuckClaims.length === 0) {
        add("Live", `no file-claims stuck > 10 min`, "pass");
      } else {
        for (const c of stuckClaims) {
          const ageMin = Math.round((Date.now() - Date.parse(c.acquired_at)) / 60_000);
          add(
            "Live",
            `claim on ${c.file_path} held ${ageMin} min by ${c.session_id.slice(0, 12)}`,
            "warn",
            `batonq release ${c.file_path}  (or batonq sweep if owner is dead)`
          );
        }
      }
      // Task-level claims stuck > 10 min.
      const stuckTasks = db
        .query(
          `SELECT external_id, repo, claimed_by, claimed_at FROM tasks
           WHERE status = 'claimed' AND claimed_at < ?`
        )
        .all(new Date(Date.now() - STUCK_MS).toISOString()) as any[];
      if (stuckTasks.length === 0) {
        add("Live", `no task-claims stuck > 10 min`, "pass");
      } else {
        for (const t of stuckTasks) {
          const ageMin = Math.round((Date.now() - Date.parse(t.claimed_at)) / 60_000);
          add(
            "Live",
            `task ${t.external_id} [${t.repo}] held ${ageMin} min by ${t.claimed_by.slice(0, 12)}`,
            "warn",
            `batonq abandon ${t.external_id}  (re-queues it for another agent)`
          );
        }
      }
    } catch (e: any) {
      add(
        "Live",
        `could not query state.db: ${e.message}`,
        "fail",
        `see State category — db is broken`
      );
    } finally {
      db?.close();
    }
  }

  // ── Render ──────────────────────────────────────────────────────────────────
  let total = 0;
  let passed = 0;
  const critical: string[] = [];
  const warnings: string[] = [];
  for (const c of cats) {
    console.log(`\n${c.name}:`);
    for (const ck of c.checks) {
      total++;
      if (ck.status === "pass") passed++;
      else if (ck.status === "fail") critical.push(`${c.name}: ${ck.label}`);
      else warnings.push(`${c.name}: ${ck.label}`);
      console.log(`  ${doctorSym(ck.status)} ${ck.label}`);
      if (ck.fix && ck.status !== "pass") {
        console.log(`      fix: ${ck.fix}`);
      }
    }
  }

  console.log();
  console.log(`Summary — batonq doctor: ${passed}/${total} checks passed.`);
  if (critical.length === 0) {
    console.log(`Critical: []`);
  } else {
    console.log(`Critical: [${critical.length}]`);
    for (const c of critical) console.log(`  - ${c}`);
  }
  if (warnings.length === 0) {
    console.log(`Warnings: []`);
  } else {
    console.log(`Warnings: [${warnings.length}]`);
    for (const w of warnings) console.log(`  - ${w}`);
  }

  process.exit(critical.length === 0 ? 0 : 1);
}

// ── tail ──────────────────────────────────────────────────────────────────────

function tail() {
  const nIdx = process.argv.indexOf("-n");
  const n = nIdx > 0 ? parseInt(process.argv[nIdx + 1] ?? "50", 10) || 50 : 50;
  if (!existsSync(LOG_PATH)) {
    console.log("(no events yet)");
    return;
  }
  const lines = readFileSync(LOG_PATH, "utf8").trim().split("\n").slice(-n);
  for (const l of lines) {
    let e: any;
    try {
      e = JSON.parse(l);
    } catch {
      continue;
    }
    const repo = e.git_root ? basename(e.git_root) : "?";
    const rel = (e.paths ?? [])
      .map((p: string) => (e.git_root ? p.replace(e.git_root + "/", "") : p))
      .join(", ");
    const pat = e.bash_pattern ? ` [${e.bash_pattern}]` : "";
    console.log(
      `${e.ts.slice(11, 19)}  ${String(e.session).slice(0, 8)}  ${e.tool.padEnd(9)} ${e.phase.padEnd(4)} ${repo}/${rel}${pat}`
    );
  }
}

