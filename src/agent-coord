function resolveRepoPath(repoName: string): string {
  if (repoName.startsWith("any:")) return process.cwd();
  for (const base of [`${HOME}/DEV`, `${HOME}/dev`]) {
    const p = `${base}/${repoName}`;
    if (existsSync(p)) {
      try {
        execSync("git rev-parse --show-toplevel", {
          cwd: p,
          stdio: ["ignore", "ignore", "ignore"],
          timeout: 1000,
        });
        return p;
      } catch {
        // not a git repo, keep looking
      }
    }
  }
  return process.cwd();
}

// Thin wrappers so the hardening invariant stays discoverable at the call-site
// in this file. Both delegate to tasks-core where the logic is unit-tested
// (see tests/core.test.ts → "runJudge fail-modes", "getGitDiffSinceClaim fail-modes").
function runJudge(judgePrompt: string, gitDiff: string, cwd: string): { passed: boolean; output: string } {
  // Invariant: PASS requires result.status === 0 && !result.error FIRST —
  // never trust stdout alone. ETIMEDOUT and other spawn errors → infra FAIL.
  return runJudgeCore(judgePrompt, gitDiff, cwd);
}

function getGitDiffSinceClaim(cwd: string, claimedAt: string): string {
  // Throws on any failure (git error, empty diff). doneTask catches the
  // throw and surfaces a judge FAIL — we must NEVER feed an empty diff
  // to the LLM (it typically answers PASS and the gate fail-opens).
  return getGitDiffSinceClaimCore(cwd, claimedAt);
}

function doneTask(id?: string): void {
  const args = process.argv.slice(3);
  const skipVerify = args.includes("--skip-verify");
  if (skipVerify && process.env.AGENT_COORD_ALLOW_SKIP !== "1") {
    console.error(
      "--skip-verify requires AGENT_COORD_ALLOW_SKIP=1 (prevents autonomous agents from bypassing verify)"
    );
    process.exit(2);
  }
  // strip flag from id lookup
  const positional = args.filter((a) => !a.startsWith("--"));
  const explicitId = positional[0];
  const db = openTaskDb();
  try {
    const session = currentSession();
    let target: any;
    if (explicitId ?? id) {
      const wanted = explicitId ?? id;
      target = db.query("SELECT * FROM tasks WHERE external_id = ?").get(wanted);
      if (!target) {
        console.error(`No task with external_id ${wanted}.`);
        process.exit(1);
      }
    } else {
      target = db
        .query(
          `SELECT * FROM tasks WHERE status = 'claimed' AND claimed_by = ? ORDER BY claimed_at DESC LIMIT 1`
        )
        .get(session);
      if (!target) {
        console.error(`No claimed task for this session. Pass the external_id explicitly.`);
        process.exit(1);
      }
    }

    // --- Verify gate ---
    if (target.verify_cmd && !skipVerify) {
      const repoPath = resolveRepoPath(target.repo);
      console.log(`→ verify: ${target.verify_cmd}`);
      console.log(`  (cwd: ${repoPath}, timeout: 300s)`);
      console.log();
      const { code, output } = runVerify(target.verify_cmd, repoPath, target.external_id);
      const truncated = output.length > 80_000 ? output.slice(0, 80_000) + "\n[truncated]" : output;
      process.stdout.write(truncated);
      console.log();
      db.run(
        `UPDATE tasks SET verify_output = ?, verify_ran_at = ? WHERE id = ?`,
        [truncated, new Date().toISOString(), target.id]
      );
      if (code !== 0) {
        console.error(`✗ verify FAILED (exit ${code}). Task stays claimed.`);
        console.error(`  Retry done after fixing, or: AGENT_COORD_ALLOW_SKIP=1 batonq done --skip-verify ${target.external_id} (logged as override)`);
        console.error(`  Or release and re-queue: batonq abandon ${target.external_id}`);
        process.exit(code);
      }
      console.log(`✓ verify passed.`);
    } else if (target.verify_cmd && skipVerify) {
      db.run(
        `UPDATE tasks SET verify_output = ?, verify_ran_at = ? WHERE id = ?`,
        [`[SKIPPED by --skip-verify]`, new Date().toISOString(), target.id]
      );
      console.log(`⚠ verify SKIPPED (--skip-verify). Override logged.`);
    }

    // --- Judge gate ---
    if (target.judge_cmd && !skipVerify) {
      const repoPath = resolveRepoPath(target.repo);
      console.log(`→ judge: ${target.judge_cmd}`);
      console.log(`  (cwd: ${repoPath})`);
      console.log();

      let gitDiff: string;
      try {
        gitDiff = getGitDiffSinceClaim(repoPath, target.claimed_at);
      } catch (e: any) {
        const msg = `[judge FAIL] ${e?.message ?? String(e)}`;
        console.error(msg);
        db.run(
          `UPDATE tasks SET judge_output = ?, judge_ran_at = ? WHERE id = ?`,
          [msg, new Date().toISOString(), target.id]
        );
        console.error(`✗ judge FAILED. Task stays claimed.`);
        console.error(`  Fix issues and retry: batonq done ${target.external_id}`);
        console.error(`  Or release and re-queue: batonq abandon ${target.external_id}`);
        process.exit(1);
      }

      const { passed, output } = runJudge(target.judge_cmd, gitDiff, repoPath);

      const truncated = output.length > 80_000 ? output.slice(0, 80_000) + "\n[truncated]" : output;
      process.stdout.write(truncated);
      console.log();

      db.run(
        `UPDATE tasks SET judge_output = ?, judge_ran_at = ? WHERE id = ?`,
        [truncated, new Date().toISOString(), target.id]
      );

      if (!passed) {
        console.error(`✗ judge FAILED. Task stays claimed.`);
        console.error(`  Fix issues and retry: batonq done ${target.external_id}`);
        console.error(`  Or release and re-queue: batonq abandon ${target.external_id}`);
        process.exit(1);
      }
      console.log(`✓ judge passed.`);
    }

    db.run(
      `UPDATE tasks SET status = 'done', completed_at = ? WHERE id = ?`,
      [new Date().toISOString(), target.id]
    );
    rewriteMdTaskStatus(target.repo, target.body, "done");
    console.log(`✓ done: [${target.repo}] ${target.body}`);
  } finally {
    db.close();
  }
}

function abandonTask(id?: string): void {
  const db = openTaskDb();
  try {
    const session = currentSession();
    let target: any;
    if (id) {
      target = db.query("SELECT * FROM tasks WHERE external_id = ?").get(id);
    } else {
      target = db
        .query(
          `SELECT * FROM tasks WHERE status = 'claimed' AND claimed_by = ? ORDER BY claimed_at DESC LIMIT 1`
        )
        .get(session);
    }
    if (!target) {
      console.error("No matching task.");
      process.exit(1);
    }
    db.run(
      `UPDATE tasks SET status = 'pending', claimed_by = NULL, claimed_at = NULL WHERE id = ?`,
      [target.id]
    );
    console.log(`↺ abandoned (re-queued): [${target.repo}] ${target.body}`);
  } finally {
    db.close();
  }
}

