#!/bin/bash
set -euo pipefail

# batonq-loop — Path A: Fresh agent invocation per task via batonq agent-run.
#
# Polls `batonq pick` and dispatches each claimed task through the agent-runner
# abstraction (src/agent-runners/*) instead of hard-coding `claude -p`. The
# picked agent + model come from the routing layer (src/agent-runners/
# routing.ts) and are emitted on `agent:` / `model:` lines in pick output.
# The task's `role` (worker / judge / pr-runner / explorer / reviewer) flows
# through the same channel so the runner can inject the matching SKILL.md
# from `Salberg87/batonq-skills` into the agent's system prompt.
#
# Two operator-side escape hatches sit on top of routing:
#
#   BATONQ_FORCE_AGENT=<tool>   pin every dispatch to <tool> regardless of
#                               what routing decided. Useful when one CLI is
#                               broken/rate-limited and you want every task
#                               pushed through one runner without re-routing
#                               rows in the DB.
#   <tool> not on PATH          silently fall back to claude. claude is the
#                               historical default; we treat it as the
#                               last-resort runner expected to be present
#                               on every host.
#
# Deps: a `timeout` binary (GNU coreutils). macOS ships without one, so
#   `brew install coreutils` gives you `gtimeout`. Linux ships `timeout`
#   natively. batonq_timeout_cmd (from batonq-platform-compat.sh) branches
#   on `uname` (Darwin vs linux/other) and picks the right name at runtime.
#
# Env:
#   BATONQ_WATCHDOG_STALE_SEC   watchdog mtime-staleness threshold (default 600)
#   BATONQ_WATCHDOG_WARMUP_SEC  watchdog warm-up before first check (default 120)
#   BATONQ_LOOP_TIMEOUT         timeout duration for dispatch (default 20m)
#   BATONQ_FORCE_AGENT          ops-time agent pin (overrides routing)
#
# Multi-session caveat: the watchdog watches a *shared* hook log
# (~/.claude/batonq-measurement/events.jsonl). The events log is written by
# the hook regardless of which agent ran, so the watchdog stays agnostic to
# which CLI was dispatched.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=./batonq-platform-compat.sh
. "${SCRIPT_DIR}/batonq-platform-compat.sh"

PICK_NEXT_SYSTEM_PROMPT="$(cat ~/.claude/commands/pick-next.md)"

LOOP_TIMEOUT="${BATONQ_LOOP_TIMEOUT:-20m}"
TIMEOUT_CMD="$(batonq_timeout_cmd)"

# extract_pick_field <key> — pull the right-hand value of `<key>: <value>`
# lines from $PICK_OUTPUT. Returns empty string if the key is absent so the
# caller can ${var:-default} their own fallback. awk is used over sed to
# avoid escaping headaches in the BRE regex.
extract_pick_field() {
  local key="$1" value
  value=$(printf '%s\n' "$PICK_OUTPUT" \
            | awk -F: -v k="$key" '$1 == k { sub(/^[^:]*:[[:space:]]*/, ""); print; exit }')
  printf '%s' "$value"
}

while true; do
  echo "→ batonq pick"
  PICK_OUTPUT=$(batonq pick 2>&1)

  if [[ "$PICK_OUTPUT" =~ ^NO_TASK ]]; then
    echo "$PICK_OUTPUT"
    echo "Queue empty. Sleeping 60s..."
    sleep 60
    continue
  fi

  if [[ "$PICK_OUTPUT" =~ ^TASK_CLAIMED ]]; then
    echo "$PICK_OUTPUT"
    echo

    # Routing decision propagated by `batonq pick` (resolved via src/agent-
    # runners/routing.ts). Empty for legacy DB rows that pre-date routing —
    # default to claude/sonnet to preserve the old hard-coded behaviour.
    AGENT="$(extract_pick_field agent)"
    MODEL="$(extract_pick_field model)"
    ROLE="$(extract_pick_field role)"
    AGENT="${AGENT:-claude}"
    MODEL="${MODEL:-sonnet}"
    ROLE="${ROLE:-worker}"

    if [ -n "${BATONQ_FORCE_AGENT:-}" ]; then
      echo "→ BATONQ_FORCE_AGENT=${BATONQ_FORCE_AGENT} (overrides picked: ${AGENT})"
      AGENT="${BATONQ_FORCE_AGENT}"
    fi

    # Availability gate: if the chosen runner isn't on PATH, fall back to
    # claude. The fallback applies equally to a routing pick and to a
    # BATONQ_FORCE_AGENT pin — surprising the operator with a hung dispatch
    # is worse than a logged fallback they can spot in the loop output.
    if ! command -v "$AGENT" >/dev/null 2>&1; then
      echo "→ ${AGENT} not on PATH; falling back to claude"
      AGENT="claude"
    fi

    echo "→ dispatching: batonq agent-run --tool=${AGENT} --model=${MODEL} --role=${ROLE}"
    echo

    # Liveness watchdog: if the shared hook event log goes mtime-stale for
    # BATONQ_WATCHDOG_STALE_SEC, kill the gtimeout/agent tree so the loop
    # rolls forward. Default 600s (10 min), overridable via env. The
    # watchdog kills the gtimeout process by name; agent-run runs as a
    # grandchild via gtimeout so the kill propagates regardless of which
    # CLI we dispatched to.
    WATCHDOG_CMD="$(command -v batonq-loop-watchdog \
                || command -v agent-coord-loop-watchdog \
                || echo "$(dirname "$0")/agent-coord-loop-watchdog")"
    "$WATCHDOG_CMD" $$ "$HOME/.claude/batonq-measurement/events.jsonl" &
    WATCHDOG_PID=$!

    # `|| true` prevents `set -e` from tearing down the loop when the timeout
    # wrapper (124) or agent-run returns non-zero — we want the outer loop to
    # keep running. The full pick output is passed as --prompt so the picked
    # agent has the same context (external_id, body, "When complete: batonq
    # done <id>") that claude got under the previous hard-coded path.
    "$TIMEOUT_CMD" "$LOOP_TIMEOUT" batonq agent-run \
        --tool="$AGENT" \
        --model="$MODEL" \
        --role="$ROLE" \
        --prompt="$PICK_OUTPUT" \
        --system-prompt="$PICK_NEXT_SYSTEM_PROMPT" || true

    # Clean up watchdog (task done or killed)
    kill "$WATCHDOG_PID" 2>/dev/null || true
    wait "$WATCHDOG_PID" 2>/dev/null || true

    # Wait before next pick
    echo
    echo "→ sleeping 5s before next task..."
    sleep 5
    continue
  fi

  # Unexpected output
  echo "✗ Unexpected batonq pick output:"
  echo "$PICK_OUTPUT"
  echo "Sleeping 60s..."
  sleep 60
done
